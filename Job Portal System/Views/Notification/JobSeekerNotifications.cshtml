@model IEnumerable<Job_Portal_System.NOTIFICATION>
@{
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
}

<style>
    .notif-container {
        max-width: 850px;
        margin: auto;
    }

    .notif-item {
        display: flex;
        align-items: flex-start;
        padding: 18px 24px;
        margin-bottom: 16px;
        border-radius: 16px;
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

        .notif-item.unread {
            border-left: 4px solid #00FF88;
            background: rgba(0, 255, 136, 0.05);
        }

        .notif-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3);
            border-color: rgba(255, 255, 255, 0.15);
        }

    .notif-icon {
        width: 48px;
        height: 48px;
        min-width: 48px;
        min-height: 48px;
        border-radius: 50%;
        background: rgba(0, 255, 136, 0.1);
        color: #00FF88;
        border: 1px solid rgba(0, 255, 136, 0.2);
        font-size: 20px;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-right: 20px;
        flex-shrink: 0;
    }


    .notif-body {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 48px;
    }

    .notif-message {
        font-size: 15px;
        font-weight: 500;
        color: #fff;
        line-height: 1.5;
        margin-bottom: 6px;
    }

    .notif-time {
        font-size: 13px;
        color: #94A3B8;
        font-weight: 500;
    }

    .notif-action {
        display: flex;
        align-items: center;
        justify-content: center;
        padding-left: 20px;
        min-height: 48px;
    }

    .notif-action button {
        background: transparent;
        padding: 8px 16px;
        border-radius: 8px;
        color: #00FF88;
        border: 1px solid rgba(0, 255, 136, 0.4);
        font-size: 13.5px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s;
        white-space: nowrap;
    }

        .notif-action button:hover {
            background: rgba(0, 255, 136, 0.15);
            border-color: #00FF88;
            box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
            transform: translateY(-1px);
        }
        
    .page-title {
        color: #fff;
        font-weight: 700;
        font-size: 26px;
        margin-bottom: 30px;
        letter-spacing: -0.5px;
    }
    
    .empty-state {
        color: #94A3B8;
        background: rgba(18, 18, 18, 0.6);
        padding: 40px;
        border-radius: 16px;
        text-align: center;
        border: 1px dashed rgba(255, 255, 255, 0.08);
        font-size: 15px;
    }
</style>



<h2 class="page-title">My Notifications</h2>

@if (!Model.Any())
{
    <div class="empty-state">No notifications yet.</div>
}
else
{
    <div class="notif-container">
        @foreach (var note in Model)
        {
            <div class="notif-item @(note.read_status == "UNREAD" ? "unread" : "read")">

                <div class="notif-icon">
                    <i class="fa-solid fa-bell"></i>
                </div>


                <div class="notif-body">
                    <div class="notif-message">@note.message</div>
                    <div class="notif-time">
                        @(note.created_at)
                    </div>
                </div>

                <div class="notif-action">
                    @if (note.read_status == "UNREAD")
                    {
                        using (Html.BeginForm("JobSeekerMarkAsRead", "Notification", FormMethod.Post))
                        {
                            @Html.Hidden("id", note.notification_id)
                            <button type="submit">Mark as Read</button>
                        }
                    }
                </div>

            </div>
        }
    </div>
}
