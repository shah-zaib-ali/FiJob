                @Html.EditorFor(model => model.notification_id)
                @Html.ValidationMessageFor(model => model.notification_id)
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.user_id, "user_id", new { @class = "control-label col-md-2" })
