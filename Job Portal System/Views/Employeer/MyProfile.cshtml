@model Job_Portal_System.ViewModel.EmployerProfileViewModel
@{
    ViewBag.Title = "My Profile";
    Layout = "~/Views/Shared/_EmployeerDashboard.cshtml";
}

<style>
    /* Hero Section */
    .profile-hero {
        background: linear-gradient(135deg, rgba(18, 18, 18, 0.9), rgba(0, 255, 136, 0.05));
        padding: 50px 30px;
        text-align: center;
        color: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.3);
        margin-bottom: 25px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
    }

        .profile-hero img {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            border: 4px solid rgba(0, 255, 136, 0.8);
            object-fit: cover;
            box-shadow: 0px 8px 24px rgba(0, 255, 136, 0.3);
            margin-bottom: 12px;
            background: #fff;
        }

    .hero-name {
        font-size: 32px;
        font-weight: 800;
        margin-top: 15px;
        letter-spacing: -0.5px;
        color: #fff;
    }

    .hero-tagline {
        font-size: 16px;
        color: #94A3B8;
        font-weight: 500;
        margin-top: 5px;
    }

    /* Main Profile Card */
    .profile-details-card {
        max-width: 900px;
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        margin: auto;
        padding: 40px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 12px 32px rgba(0,0,0,0.2);
        margin-bottom: 40px;
        color: #E2E8F0;
    }

    .info-title {
        font-weight: 700;
        font-size: 18px;
        color: #fff;
        margin-bottom: 30px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .info-item {
        display: flex;
        margin-bottom: 22px;
        align-items: flex-start;
        padding-left: 10px;
    }

        .info-item i {
            font-size: 20px;
            color: #00FF88;
            width: 40px;
            margin-top: 10px;
        }

    .info-text-title {
        font-weight: 600;
        color: #94A3B8;
        font-size: 13.5px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 8px;
        display: block;
    }

    .form-control, input[type="file"] {
        border-radius: 10px;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        padding: 12px 16px;
        font-size: 15px;
        transition: 0.3s;
        width: 100%;
    }
    
    .form-control:focus, input[type="file"]:focus {
        background: rgba(0, 0, 0, 0.4);
        border-color: #00FF88;
        box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.15);
        color: #fff;
        outline: none;
    }

    .edit-profile-btn, .btn-save, .btn-cancel {
        padding: 14px 32px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: none;
        cursor: pointer;
    }

    .btn-save {
        background: #00FF88;
        color: #0B0B0B;
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
        margin-right: 12px;
    }

        .btn-save:hover {
            background: #00DF77;
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 6px 20px rgba(0, 255, 136, 0.35);
            color: #0B0B0B;
        }

    .btn-cancel {
        background: transparent;
        color: #E2E8F0;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

        .btn-cancel:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            border-color: rgba(255, 255, 255, 0.4);
            transform: translateY(-2px);
        }
        
    input[type="file"]::file-selector-button {
        background: rgba(255, 255, 255, 0.1);
        border: none;
        border-radius: 6px;
        color: #fff;
        padding: 6px 12px;
        margin-right: 12px;
        cursor: pointer;
        transition: 0.2s;
    }
    
    input[type="file"]::file-selector-button:hover {
        background: rgba(255, 255, 255, 0.2);
    }
</style>

<!-- HERO SECTION -->
<div class="profile-hero">
    <img src="@(!string.IsNullOrEmpty(Model.CompanyLogo) ? Url.Content(Model.CompanyLogo + "?" + DateTime.Now.Ticks) : Url.Content("~/Images/CompanyLogos/default-logo.webp"))" alt="Company Logo" />

    <h2 class="hero-name">@Model.FullName</h2>
    <p class="hero-tagline">@Model.CompanyName — @Model.Industry</p>
</div>

<!-- MAIN DETAILS CARD -->
<div class="profile-details-card">
    <div class="info-title">Company Profile</div>

    @using (Html.BeginForm("MyProfile", "Employeer", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()

        <!-- Upload Logo -->
        <div class="form-group info-item">
            <i class="fa-solid fa-image"></i>
            <div style="flex:1;">
                @Html.Label("Company Logo", new { @class = "info-text-title" })
                <input type="file" name="CompanyLogoFile" class="form-control" />
            </div>
        </div>

        <div class="form-group info-item">
            <i class="fa-solid fa-user"></i>
            <div style="flex:1;">
                @Html.LabelFor(m => m.FullName, new { @class = "info-text-title" })
                @Html.TextBoxFor(m => m.FullName, new { @class = "form-control" })
            </div>
        </div>

        <div class="form-group info-item">
            <i class="fa-solid fa-building"></i>
            <div style="flex:1;">
                @Html.LabelFor(m => m.CompanyName, new { @class = "info-text-title" })
                @Html.TextBoxFor(m => m.CompanyName, new { @class = "form-control" })
            </div>
        </div>

        <div class="form-group info-item">
            <i class="fa-solid fa-industry"></i>
            <div style="flex:1;">
                @Html.LabelFor(m => m.Industry, new { @class = "info-text-title" })
                @Html.TextBoxFor(m => m.Industry, new { @class = "form-control" })
            </div>
        </div>

        <div class="form-group info-item">
            <i class="fa-solid fa-align-left"></i>
            <div style="flex:1;">
                @Html.LabelFor(m => m.CompanyDescription, new { @class = "info-text-title" })
                @Html.TextAreaFor(m => m.CompanyDescription, new { @class = "form-control", rows = 5 })
            </div>
        </div>

        <div class="form-group info-item">
            <i class="fa-solid fa-globe"></i>
            <div style="flex:1;">
                @Html.LabelFor(m => m.Website, new { @class = "info-text-title" })
                @Html.TextBoxFor(m => m.Website, new { @class = "form-control" })
            </div>
        </div>

        <div class="form-group info-item">
            <i class="fa-solid fa-location-dot"></i>
            <div style="flex:1;">
                @Html.LabelFor(m => m.Location, new { @class = "info-text-title" })
                @Html.TextBoxFor(m => m.Location, new { @class = "form-control" })
            </div>
        </div>

        <div class="text-center mt-4">
            <input type="submit" value="Save Changes" class="btn-save" />
            <a href="@Url.Action("Dashboard", "Employeer")" class="btn-cancel">Cancel</a>
        </div>
    }
</div>
