@model Job_Portal_System.USER
@{
    ViewBag.Title = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background-color: #0b0b0b;
        font-family: 'Segoe UI', Inter, Tahoma, Geneva, Verdana, sans-serif;
        color: #fff;
    }

    .register-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 85vh;
        padding: 40px 0;
    }

    .register-card {
        background: rgba(18, 18, 18, 0.7);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        width: 480px;
        padding: 40px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
    }

    .register-title {
        text-align: center;
        color: #fff;
        font-weight: 700;
        margin-bottom: 25px;
        font-size: 26px;
    }

    label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #cbd5e1;
        margin-bottom: 6px;
        text-align: left;
    }

    .form-group {
        margin-bottom: 20px;
        color: #fff;
    }

    .form-control {
        width: 100%;
        padding: 12px 14px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
        font-size: 14px;
        color: #fff;
        outline: none;
    }

    .form-control:focus {
        background: rgba(255, 255, 255, 0.06);
        border-color: #00FF88;
        box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.15);
    }

    select.form-control {
        cursor: pointer;
        appearance: none;
    }
    
    select.form-control option {
        background: #121212;
        color: #fff;
    }

    .btn-register {
        width: 100%;
        padding: 14px;
        background: #00FF88;
        color: #0b0b0b;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 10px;
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
    }

    .btn-register:hover {
        background: #00DF77;
        transform: translateY(-1px) scale(1.02);
        box-shadow: 0 6px 16px rgba(0, 255, 136, 0.35);
    }

    .alert {
        margin-bottom: 20px;
        border-radius: 8px;
        padding: 12px;
        text-align: left;
        font-weight: 500;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .alert-danger {
        color: #ff6b6b;
        background: rgba(255, 107, 107, 0.1);
        border: 1px solid rgba(255, 107, 107, 0.3);
    }
</style>

<div class="register-container">

    <div class="register-card">

        <h2 class="register-title">Create Account</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        @using (Html.BeginForm("Register", "Account", FormMethod.Post))
        {
            <div class="form-group">
                @Html.LabelFor(m => m.full_name , "Full Name")
                @Html.TextBoxFor(m => m.full_name, new { @class = "form-control", placeholder = "Enter full name" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.username , "Username")
                @Html.TextBoxFor(m => m.username, new { @class = "form-control", placeholder = "Choose username" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.email , "E-mail")
                @Html.TextBoxFor(m => m.email, new { @class = "form-control", placeholder = "Enter email address" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.password_hash, "Password")
                <input type="password" name="password_hash" class="form-control" placeholder="Create password" />
            </div>

            <div class="form-group">
                @Html.Label("Confirm Password")
                <input type="password" name="confirmPassword" class="form-control" placeholder="Confirm password" />
            </div>

            <div class="form-group">
                <label>Select Role</label>
                <select name="selectedRole" class="form-control">
                    <option value="">-- Select Role --</option>
                    <option value="Job Seeker">Job Seeker</option>
                    <option value="Employer">Employer</option>
                </select>
            </div>

            <button type="submit" class="btn-register">Register</button>
        }

    </div>

</div>