@{
    ViewBag.Title = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - FiJob Portal</title>
    <!-- Add Favicon -->
    <link rel="icon" type="image/png" href="~/Images/CompanyLogos/fijob_logo.png">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: #0b0b0b;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            color: #fff;
        }

        .auth-container {
            background: rgba(18, 18, 18, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            width: 100%;
            max-width: 400px;
            padding: 40px;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
            text-align: center;
        }

        .logo-container {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 30px;
            text-decoration: none;
        }

        .logo-mark {
            width: 40px;
            height: 40px;
            background: #00FF88;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 12px rgba(0, 255, 136, 0.4);
        }

        .logo-mark svg {
            width: 24px;
            height: 24px;
            fill: #0b0b0b;
        }

        .logo-text {
            font-size: 24px;
            font-weight: 700;
            color: #fff;
        }

        .logo-text span {
            color: #00FF88;
        }

        .auth-title {
            font-size: 24px;
            font-weight: 700;
            color: #fff;
            margin-bottom: 8px;
        }

        .auth-subtitle {
            font-size: 14px;
            color: #94a3b8;
            margin-bottom: 30px;
        }

        .input-group {
            text-align: left;
            margin-bottom: 20px;
            position: relative;
        }

        .input-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #cbd5e1;
            margin-bottom: 6px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #64748b;
            font-size: 14px;
            transition: color 0.3s ease;
        }

        .input-group input {
            width: 100%;
            padding: 12px 14px 12px 40px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            font-size: 14px;
            color: #fff;
            transition: all 0.3s ease;
            outline: none;
            background: rgba(255, 255, 255, 0.03);
        }

        .input-group input:focus {
            background: rgba(255, 255, 255, 0.06);
            border-color: #00FF88;
            box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.15);
        }
        
        .input-group input:focus + i, 
        .input-group input:focus ~ i {
            color: #00FF88;
        }

        .auth-btn {
            width: 100%;
            padding: 14px;
            background: #00FF88;
            color: #0b0b0b;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
            box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
        }

        .auth-btn:hover {
            background: #00DF77;
            transform: translateY(-1px) scale(1.02);
            box-shadow: 0 6px 16px rgba(0, 255, 136, 0.35);
        }

        .auth-footer {
            margin-top: 25px;
            font-size: 14px;
            color: #94a3b8;
        }

        .auth-footer a {
            color: #00FF88;
            font-weight: 600;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .auth-footer a:hover {
            text-decoration: underline;
            text-shadow: 0 0 8px rgba(0, 255, 136, 0.4);
        }

        .error-message {
            color: #ff6b6b;
            background: rgba(255, 107, 107, 0.1);
            border: 1px solid rgba(255, 107, 107, 0.3);
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 20px;
            text-align: left;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .success-message {
            color: #00FF88;
            background: rgba(0, 255, 136, 0.1);
            border: 1px solid rgba(0, 255, 136, 0.3);
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 20px;
            text-align: left;
            display: flex;
            align-items: center;
            gap: 10px;
        }
    </style>
</head>
<body>

    <div class="auth-container">
        
        <a href="#" class="logo-container">
            <div class="logo-mark">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M20 7h-4V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zm-10-2h4v2h-4V5zm2 11a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm6-4H6v-1l2-2h8l2 2v1z" />
                </svg>
            </div>
            <div class="logo-text">Fi<span>Job</span></div>
        </a>

        <h2 class="auth-title">Welcome Back</h2>
        <p class="auth-subtitle">Sign in to continue to your dashboard</p>

        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="error-message">
                <i class="fa-solid fa-circle-exclamation"></i>
                @ViewBag.Error
            </div>
        }
        
        @if (!string.IsNullOrEmpty(ViewBag.Success) || !string.IsNullOrEmpty(ViewBag.Message))
        {
            <div class="success-message">
                <i class="fa-solid fa-circle-check"></i>
                @(ViewBag.Success ?? ViewBag.Message)
            </div>
        }

        @using (Html.BeginForm("Login", "Account", FormMethod.Post))
        {
            <div class="input-group">
                <label>Email Address or Username</label>
                <div class="input-wrapper">
                    <i class="fa-regular fa-envelope"></i>
                    <input type="text" name="email" placeholder="you@example.com" required autocomplete="off" />
                </div>
            </div>

            <div class="input-group">
                <label>Password</label>
                <div class="input-wrapper">
                    <i class="fa-solid fa-lock"></i>
                    <input type="password" name="password" placeholder="Enter your password" required autocomplete="current-password" />
                </div>
            </div>

            <button type="submit" class="auth-btn">Login to Account</button>
        }

        <div class="auth-footer">
            Don't have an account? <a href="/Account/Register">Create an account</a>
        </div>
    </div>

</body>
</html>
