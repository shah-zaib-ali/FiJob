@model IEnumerable<Job_Portal_System.Skill>

@{
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
    // Fetch the jobs from ViewBag
    var recommendedJobs = ViewBag.RecommendedJobs as IEnumerable<Job_Portal_System.JOB>;
}

<div class="skills-container">
    <div class="skills-header">
        <h2 class="title">My Skills</h2>
        <p class="subtitle">Add, update and manage your professional skill set.</p>
    </div>

    <div class="add-skill-box">
        <form method="post" action="/JobSeeker/AddSkill" class="skill-form">
            <input name="SkillName" class="skill-input" placeholder="Enter a new skill..." required autocomplete="off" />
            <button class="skill-add-btn">Add Skill</button>
        </form>
    </div>

    <div class="skills-section">
        <h4 class="section-title">Your Added Skills</h4>
        <div class="skills-tags-wrapper">
            @foreach (var item in Model)
            {
                <div class="skill-tag-box">
                    <span class="skill-text">@item.skillName</span>
                    <a href="/JobSeeker/DeleteSkill/@item.SkillID" class="skill-delete-btn">✕</a>
                </div>
            }
        </div>
    </div>

    <div class="jobs-section">
        <h4 class="section-title">Recommended Jobs for You</h4>
        <p class="subtitle">Based on your current skill set</p>

        <div class="jobs-grid">
            @if (recommendedJobs != null && recommendedJobs.Any())
            {
                foreach (var job in recommendedJobs)
                {
                    <div class="job-card">
                        <div class="job-info">
                            <h5 class="job-title">@job.job_title</h5>
                            <p class="job-company"><i class="fas fa-building"></i> @job.job_description</p>
                        </div>
                        <a href="/Job/JobDetails/@job.job_id" class="view-job-btn">View Details</a>
                    </div>
                }
            }
            else
            {
                <div class="no-jobs-alert">
                    <i class="fa-solid fa-ghost"></i> No matching jobs found at this time. Try adding more skills!
                </div>
            }
        </div>
    </div>
</div>


<style>
    body {
        font-family: inherit !important;
        background-color: #0b0b0b;
        color: #e2e8f0;
    }

    .skills-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 30px;
    }

    /* HEADER */
    .title {
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin-bottom: 8px;
    }

    .subtitle {
        color: #94a3b8;
        font-size: 15px;
        margin-bottom: 25px;
    }

    /* ADD BOX */
    .add-skill-box {
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        padding: 24px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 12px 32px rgba(0,0,0,0.2);
        margin-bottom: 40px;
    }

    .skill-form {
        display: flex;
        gap: 15px;
    }

    .skill-input {
        flex: 1;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 12px 18px;
        font-size: 15px;
        color: #fff;
        transition: 0.3s;
        outline: none;
    }

        .skill-input:focus {
            background: rgba(0, 0, 0, 0.4);
            border-color: #00FF88;
            box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.15);
        }

    .skill-add-btn {
        background: #00FF88;
        color: #0b0b0b;
        border: none;
        padding: 12px 28px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
    }

        .skill-add-btn:hover {
            background: #00DF77;
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 6px 20px rgba(0, 255, 136, 0.35);
        }

    /* TAGS */
    .skills-section {
        margin-bottom: 50px;
    }

    .section-title {
        color: #fff;
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .skills-tags-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .skill-tag-box {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(0, 255, 136, 0.05);
        border: 1px solid rgba(0, 255, 136, 0.2);
        padding: 8px 16px;
        border-radius: 30px;
        color: #e2e8f0;
        font-size: 14px;
        font-weight: 500;
        transition: 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

        .skill-tag-box:hover {
            background: rgba(0, 255, 136, 0.15);
            border-color: #00FF88;
            box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
            transform: translateY(-2px);
            color: #fff;
        }

    .skill-delete-btn {
        background: transparent;
        color: #94a3b8;
        border: none;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: bold;
        text-decoration: none;
        cursor: pointer;
        transition: 0.2s;
    }

        .skill-delete-btn:hover {
            background: rgba(239, 68, 68, 0.15);
            color: #EF4444;
            transform: scale(1.1);
        }

    /* JOBS */
    .jobs-section {
        margin-top: 30px;
    }

    .jobs-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
        margin-top: 25px;
    }

    .job-card {
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        padding: 24px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 12px 32px rgba(0,0,0,0.2);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

        .job-card:hover {
            transform: translateY(-4px);
            border-color: rgba(0, 255, 136, 0.3);
            box-shadow: 0 16px 40px rgba(0, 255, 136, 0.1);
        }

    .job-title {
        font-size: 18px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 6px;
        letter-spacing: -0.2px;
    }

    .job-company {
        font-size: 14px;
        color: #94a3b8;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .job-company i {
            color: #00FF88;
        }

    .view-job-btn {
        background: transparent;
        color: #00FF88;
        border: 1px solid rgba(0, 255, 136, 0.4);
        padding: 10px;
        text-align: center;
        display: block;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
        margin-top: auto;
    }

        .view-job-btn:hover {
            background: rgba(0, 255, 136, 0.15);
            border-color: #00FF88;
            box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
            color: #00FF88;
            transform: translateY(-1px);
        }

    .no-jobs-alert {
        background: rgba(255, 255, 255, 0.03);
        color: #94a3b8;
        padding: 40px 20px;
        border-radius: 16px;
        font-size: 15px;
        width: 100%;
        grid-column: 1 / -1;
        text-align: center;
        border: 1px dashed rgba(255, 255, 255, 0.1);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }
    
    .no-jobs-alert i {
        font-size: 28px;
        color: rgba(255, 255, 255, 0.2);
    }
</style>
