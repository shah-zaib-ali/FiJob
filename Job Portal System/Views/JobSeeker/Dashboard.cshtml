@model Job_Portal_System.ViewModel.JobSeekerStatsViewModel
@{
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
    var stats = Model;
}

<!-- ApexCharts Script -->
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<style>
    /* Dashboard Hero Section */
    .dashboard-hero {
        background: linear-gradient(135deg, rgba(18, 18, 18, 0.9), rgba(0, 255, 136, 0.05));
        padding: 50px 30px;
        text-align: center;
        color: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.3);
        margin-bottom: 40px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
    }

    .dashboard-hero h2 {
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 10px;
        color: #fff;
    }

    .dashboard-hero p {
        font-size: 16px;
        color: #94A3B8;
        margin: 5px 0;
    }

    /* Modern KPI Cards */
    .dashboard-grid {
        display: flex;
        gap: 25px;
        justify-content: center;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }

    .kpi-card {
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        padding: 25px;
        min-width: 260px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.2);
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        text-align: center;
    }

    .kpi-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 40px rgba(0,0,0,0.3);
        border-color: rgba(255, 255, 255, 0.15);
    }

    .kpi-icon {
        font-size: 35px;
        margin-bottom: 15px;
    }

    .kpi-title {
        font-size: 13px;
        color: #94A3B8;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
    }

    .kpi-number {
        font-size: 42px;
        font-weight: 800;
        color: #fff;
        line-height: 1;
        margin: 0;
    }

    .kpi-bg {
        position: absolute;
        top: -30px;
        right: -30px;
        font-size: 150px;
        opacity: 0.02;
        z-index: 0;
        color: #fff;
    }

    .kpi-content {
        position: relative;
        z-index: 1;
    }

    /* Charts Container */
    .chart-box {
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.2);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .chart-title {
        color: #fff;
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .chart-title i {
        color: #F59E0B;
    }
    
    /* Skills Badges Grid */
    .skills-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 15px;
    }

    .skill-badge {
        background: rgba(0, 255, 136, 0.05);
        color: #E2E8F0;
        border: 1px solid rgba(0, 255, 136, 0.2);
        padding: 8px 16px;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .skill-badge:hover {
        background: rgba(0, 255, 136, 0.15);
        color: #fff;
        border-color: #00FF88;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
    }
</style>

<div class="dashboard-hero">
    <h2>Your Activity Overview</h2>
    <p>Track your saved jobs and professional growth metrics.</p>
</div>

<div style="max-width:1100px; margin: auto; padding: 0 20px;">

    <!-- KPI Summary Grid -->
    <div class="dashboard-grid">
        <div class="kpi-card" style="border-top: 4px solid #00FF88;">
            <i class="fas fa-bookmark kpi-bg"></i>
            <div class="kpi-content">
                <div class="kpi-icon" style="color: #00FF88;"><i class="fas fa-bookmark"></i></div>
                <div class="kpi-title">Saved Jobs</div>
                <h3 class="kpi-number">@Model.SavedJobs</h3>
            </div>
        </div>

        <div class="kpi-card" style="border-top: 4px solid #F59E0B;">
            <i class="fas fa-tools kpi-bg"></i>
            <div class="kpi-content">
                <div class="kpi-icon" style="color: #F59E0B;"><i class="fas fa-tools"></i></div>
                <div class="kpi-title">Skills & Education Found</div>
                <h3 class="kpi-number">@Model.TotalSkills</h3>
            </div>
        </div>
    </div>

    <!-- Chart row -->
    <div class="row">
        <!-- Doughnut Skills Chart -->
        <div class="col-lg-12">
            <div class="chart-box">
                <div class="chart-title">
                    <i class="fas fa-bolt text-warning"></i> Professional Skill Set Highlighted
                </div>
                <div id="skillsDoughnutChart" style="padding: 20px; min-height: 100px;">
                    @if (ViewBag.UserSkills != null)
                    {
                        var skills = (IEnumerable<Job_Portal_System.Skill>)ViewBag.UserSkills;
                        if (skills.Any())
                        {
                            <div class="skills-grid">
                                @foreach (var s in skills)
                                {
                                    <span class="skill-badge">
                                        <i class="fa-solid fa-check-circle" style="color: #00FF88; font-size: 13px;"></i>
                                        @s.skillName
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <p style="color: #94A3B8; font-style: italic;">No specific skills have been added yet.</p>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
    });
</script>
