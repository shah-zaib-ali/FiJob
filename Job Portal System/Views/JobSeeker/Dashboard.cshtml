@model Job_Portal_System.ViewModel.JobSeekerStatsViewModel
@{
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
    var stats = Model;
}

<!-- ApexCharts Script -->
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<style>
    /* Dashboard Hero Section */
    .dashboard-hero {
        background: linear-gradient(to right, #002E7F, #004bb8);
        padding: 50px 30px;
        text-align: center;
        color: white;
        border-radius: 0 0 20px 20px;
        box-shadow: 0 4px 25px rgba(0,0,0,0.15);
        margin-bottom: 40px;
    }

    .dashboard-hero h2 {
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .dashboard-hero p {
        font-size: 16px;
        opacity: 0.9;
        margin: 5px 0;
    }

    /* Modern KPI Cards */
    .dashboard-grid {
        display: flex;
        gap: 25px;
        justify-content: center;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }

    .kpi-card {
        background: #fff;
        border-radius: 16px;
        padding: 25px;
        min-width: 260px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.06);
        position: relative;
        overflow: hidden;
        border: 1px solid #edf2f7;
        transition: 0.3s;
        text-align: center;
    }

    .kpi-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.1);
    }

    .kpi-icon {
        font-size: 35px;
        margin-bottom: 15px;
        opacity: 0.9;
    }

    .kpi-title {
        font-size: 15px;
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 10px;
    }

    .kpi-number {
        font-size: 42px;
        font-weight: 800;
        color: #0f172a;
        line-height: 1;
        margin: 0;
    }

    .kpi-bg {
        position: absolute;
        top: -30px;
        right: -30px;
        font-size: 150px;
        opacity: 0.03;
        z-index: 0;
    }

    .kpi-content {
        position: relative;
        z-index: 1;
    }

    /* Charts Container */
    .chart-box {
        background: #fff;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.05);
        border: 1px solid #edf2f7;
    }

    .chart-title {
        color: #0f172a;
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .chart-title i {
        color: #002E7F;
    }
    
    /* Skills Badges Grid */
    .skills-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 15px;
    }

    .skill-badge {
        background: #F0F5FF;
        color: #002E7F;
        border: 1px solid #c9defe;
        padding: 8px 16px;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.2s;
    }

    .skill-badge:hover {
        background: #002E7F;
        color: white;
        border-color: #002E7F;
        transform: translateY(-2px);
    }
</style>

<div class="dashboard-hero">
    <h2>Your Activity Overview</h2>
    <p>Track your saved jobs and professional growth metrics.</p>
</div>

<div style="max-width:1100px; margin: auto; padding: 0 20px;">

    <!-- KPI Summary Grid -->
    <div class="dashboard-grid">
        <div class="kpi-card" style="border-top: 4px solid #10b981;">
            <i class="fas fa-bookmark kpi-bg text-success"></i>
            <div class="kpi-content">
                <div class="kpi-icon" style="color: #10b981;"><i class="fas fa-bookmark"></i></div>
                <div class="kpi-title">Saved Jobs</div>
                <h3 class="kpi-number">@Model.SavedJobs</h3>
            </div>
        </div>

        <div class="kpi-card" style="border-top: 4px solid #f59e0b;">
            <i class="fas fa-tools kpi-bg text-warning"></i>
            <div class="kpi-content">
                <div class="kpi-icon" style="color: #f59e0b;"><i class="fas fa-tools"></i></div>
                <div class="kpi-title">Skills & Education Found</div>
                <h3 class="kpi-number">@Model.TotalSkills</h3>
            </div>
        </div>
    </div>

    <!-- Chart row -->
    <div class="row">
        <!-- Doughnut Skills Chart -->
        <div class="col-lg-12">
            <div class="chart-box">
                <div class="chart-title">
                    <i class="fas fa-bolt text-warning"></i> Professional Skill Set Highlighted
                </div>
                <div id="skillsDoughnutChart" style="padding: 20px; min-height: 100px;">
                    @if (ViewBag.UserSkills != null)
                    {
                        var skills = (IEnumerable<Job_Portal_System.Skill>)ViewBag.UserSkills;
                        if (skills.Any())
                        {
                            <div class="skills-grid">
                                @foreach (var s in skills)
                                {
                                    <span class="skill-badge">
                                        <i class="fa-solid fa-check-circle" style="color: #10b981; font-size: 13px;"></i>
                                        @s.skillName
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <p style="color: #64748b; font-style: italic;">No specific skills have been added yet.</p>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
    });
</script>
