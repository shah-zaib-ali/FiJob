@model Job_Portal_System.ViewModel.JobSeekerProfileViewModel
@{
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
}

<style>
    body {
        font-family: inherit !important;
        background-color: #0b0b0b;
        color: #e2e8f0;
    }
    
    /* Hero Section */
    .profile-hero {
        background: linear-gradient(135deg, rgba(18, 18, 18, 0.9), rgba(0, 255, 136, 0.05));
        padding: 50px 30px;
        text-align: center;
        color: #fff;
        border-radius: 16px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.3);
        margin-bottom: 25px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
    }

        .profile-hero img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            border: 4px solid rgba(0, 255, 136, 0.8);
            object-fit: cover;
            box-shadow: 0px 8px 24px rgba(0, 255, 136, 0.3);
            margin-bottom: 12px;
        }

    .hero-name {
        font-size: 32px;
        font-weight: 800;
        margin-top: 15px;
        letter-spacing: -0.5px;
        color: #fff;
    }

    .hero-tagline {
        font-size: 16px;
        color: #94A3B8;
        font-weight: 500;
        margin-top: 5px;
    }

    /* Main Profile Card */
    .profile-details-card {
        max-width: 900px;
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        margin: auto;
        padding: 40px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 12px 32px rgba(0,0,0,0.2);
        margin-bottom: 40px;
        color: #E2E8F0;
    }

    .info-title {
        font-weight: 700;
        font-size: 18px;
        color: #fff;
        margin-bottom: 24px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .info-item {
        display: flex;
        align-items: flex-start;
        margin-bottom: 22px;
        padding-left: 10px;
    }

        .info-item i {
            font-size: 20px;
            color: #00FF88;
            width: 40px;
            margin-top: 4px;
            flex-shrink: 0;
            display: inline-block;
        }

    .info-text-title {
        font-weight: 600;
        color: #94A3B8;
        font-size: 13.5px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 4px;
        display: block;
    }

    .info-text {
        color: #fff;
        font-size: 15.5px;
        font-weight: 500;
        line-height: 1.5;
        width: 100%;
    }
    
    .info-text a {
        color: #00FF88;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    
    .info-text a:hover {
        color: #00DF77;
        text-shadow: 0 0 8px rgba(0, 255, 136, 0.4);
    }

    .edit-profile-btn {
        background: #00FF88;
        padding: 14px 32px;
        border-radius: 12px;
        font-size: 15px;
        color: #0b0b0b;
        font-weight: 600;
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: none;
        text-decoration: none;
    }

        .edit-profile-btn:hover {
            background: #00DF77;
            color: #0b0b0b;
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 6px 20px rgba(0, 255, 136, 0.35);
            text-decoration: none;
        }
        
    .no-resume {
        color: #EF4444;
        font-weight: 500;
        font-size: 14px;
        background: rgba(239, 68, 68, 0.1);
        padding: 6px 12px;
        border-radius: 8px;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }
</style>

<!-- HERO SECTION -->
<div class="profile-hero">
    <img src="@(!string.IsNullOrEmpty(Model.ProfileImage) ? Model.ProfileImage : Url.Content("~/Content/Images/default-profile.png"))" />

    <h2 class="hero-name">@Model.FullName</h2>

    <p class="hero-tagline">
        @Model.experience_level — @Model.education
    </p>
</div>

<!-- MAIN DETAILS CARD -->
<div class="profile-details-card">

    <div class="info-title">Profile Information</div>

    <!-- BIO -->
    <div class="info-item">
        <i class="fa-solid fa-user-pen"></i>
        <div>
            <div class="info-text-title">Bio</div>
            <div class="info-text">@Model.Bio</div>
        </div>
    </div>

    <!-- DOB -->
    <div class="info-item">
        <i class="fa-solid fa-cake-candles"></i>
        <div>
            <div class="info-text-title">Date of Birth</div>
            <div class="info-text">@Model.dob</div>
        </div>
    </div>

    <!-- Gender -->
    <div class="info-item">
        <i class="fa-solid fa-venus-mars"></i>
        <div>
            <div class="info-text-title">Gender</div>
            <div class="info-text">@Model.gender</div>
        </div>
    </div>

    <!-- Phone -->
    <div class="info-item">
        <i class="fa-solid fa-phone"></i>
        <div>
            <div class="info-text-title">Phone</div>
            <div class="info-text">@Model.phone</div>
        </div>
    </div>

    <!-- Address -->
    <div class="info-item">
        <i class="fa-solid fa-location-dot"></i>
        <div>
            <div class="info-text-title">Address</div>
            <div class="info-text">@Model.address</div>
        </div>
    </div>

    <!-- Experience -->
    <div class="info-item">
        <i class="fa-solid fa-briefcase"></i>
        <div>
            <div class="info-text-title">Experience Level</div>
            <div class="info-text">@Model.experience_level</div>
        </div>
    </div>

    <!-- Education -->
    <div class="info-item">
        <i class="fa-solid fa-graduation-cap"></i>
        <div>
            <div class="info-text-title">Education</div>
            <div class="info-text">@Model.education</div>
        </div>
    </div>

    <!-- Resume -->
    <div class="info-item">
        <i class="fa-solid fa-file-lines"></i>
        <div>
            <div class="info-text-title">Resume</div>
            <div class="info-text">
                @if (!string.IsNullOrEmpty(Model.Resume))
                {
                    <a href="@Model.Resume" target="_blank"><i class="fa-solid fa-download"></i> Download Resume</a>
                }
                else
                {
                    <span class="no-resume">No Resume Uploaded</span>
                }
            </div>
        </div>
    </div>

    <div class="text-center mt-5">
        <a href="@Url.Action("MyProfile", "JobSeeker")" class="edit-profile-btn">
            <i class="fa-solid fa-pen-to-square"></i> Edit Profile
        </a>
    </div>

</div>
