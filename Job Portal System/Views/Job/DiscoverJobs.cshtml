@model IEnumerable<Job_Portal_System.ViewModel.ExternalJob>

@{
    ViewBag.Title = "Discover Jobs";
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
}

<div class="container mt-4">
    <h2 class="mb-4">Available Opportunities</h2>

    <div class="row">
        @foreach (var job in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; transition: 0.3s;">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@job.Title</h5>
                        <p class="text-muted small mb-1">
                            <i class="fas fa-building"></i> @job.Company
                        </p>
                        <p class="text-muted small mb-3">
                            <i class="fas fa-map-marker-alt"></i> @job.Location
                        </p>
                        <a href="@job.RedirectUrl" target="_blank" class="btn btn-primary btn-sm rounded-pill px-4">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>