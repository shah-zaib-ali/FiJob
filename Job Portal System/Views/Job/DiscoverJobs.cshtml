@model IEnumerable<Job_Portal_System.ViewModel.ExternalJob>

@{
    ViewBag.Title = "Discover Jobs";
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
}

<style>
    body {
        font-family: inherit !important;
        background-color: #0b0b0b;
        color: #e2e8f0;
    }
    
    .discover-container {
        padding: 30px;
        max-width: 1200px;
        margin: auto;
    }

    .page-heading {
        color: #fff;
        font-weight: 800;
        font-size: 28px;
        letter-spacing: -0.5px;
        margin-bottom: 30px;
    }

    .ext-job-card {
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        padding: 24px;
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }
    
    .ext-job-card:hover {
        transform: translateY(-4px);
        border-color: rgba(0, 191, 255, 0.3); 
        box-shadow: 0 16px 40px rgba(0, 191, 255, 0.1);
        background: rgba(255, 255, 255, 0.02);
    }

    .ext-job-title {
        color: #fff;
        font-weight: 700;
        font-size: 18px;
        margin-bottom: 12px;
        line-height: 1.4;
        letter-spacing: -0.2px;
    }

    .ext-job-meta {
        color: #94A3B8;
        font-size: 14px;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .ext-job-meta i {
        color: #00BFFF; /* Electric Blue for external jobs distinction */
        width: 16px;
        text-align: center;
    }

    .ext-btn-view {
        margin-top: auto;
        padding-top: 20px;
    }
    
    .ext-btn-link {
        background: transparent;
        color: #00BFFF;
        text-decoration: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        border: 1px solid rgba(0, 191, 255, 0.4);
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .ext-btn-link:hover {
        background: rgba(0, 191, 255, 0.15);
        border-color: #00BFFF;
        box-shadow: 0 4px 12px rgba(0, 191, 255, 0.2);
        color: #00BFFF;
        text-decoration: none;
        transform: translateY(-1px);
    }
    
    .external-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        background: rgba(0, 191, 255, 0.1);
        color: #00BFFF;
        border: 1px solid rgba(0, 191, 255, 0.2);
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 15px;
        gap: 6px;
    }
</style>

<div class="discover-container">
    <h2 class="page-heading">Discover Global Opportunities</h2>

    <div class="row">
        @foreach (var job in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="ext-job-card">
                    <div class="external-badge">
                        <i class="fa-solid fa-globe"></i> External Job
                    </div>
                    
                    <h5 class="ext-job-title">@job.Title</h5>
                    
                    <div class="ext-job-meta">
                        <i class="fas fa-building"></i> @job.Company
                    </div>
                    <div class="ext-job-meta">
                        <i class="fas fa-map-marker-alt"></i> @job.Location
                    </div>
                    
                    <div class="ext-btn-view">
                        <a href="@job.RedirectUrl" target="_blank" class="ext-btn-link">
                            View Apply Page <i class="fa-solid fa-arrow-up-right-from-square"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>