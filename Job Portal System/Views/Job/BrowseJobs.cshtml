@model IEnumerable<Job_Portal_System.JOB>

@{
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
}

<div class="jobsearch-container">

    <div class="header-section">
        <h2 class="page-title">Job Search</h2>
        <p class="page-subtitle">Find jobs that match your skills, experience and passion.</p>
    </div>

    <!-- Search Bar -->
    <form method="get" class="search-bar">
        <input name="search" class="search-input" placeholder="Job title, keyword..." />

        <input name="location" class="search-input" placeholder="Location" />

        <input name="company" class="search-input" placeholder="Company name" />

        <button type="submit" class="search-btn">Search</button>
    </form>
    
    <!-- Job Cards Section -->
    <div class="jobs-wrapper">

        @foreach (var j in Model)
        {
            <div class="job-card">

                <div class="job-info">
                    <h3 class="job-title">@j.job_title</h3>
                    <p class="job-desc">@j.job_description</p>
                </div>

                <div class="job-actions">
                    <a href="/Job/JobDetails/@j.job_id" class="view-btn"><i class="fa-solid fa-arrow-right"></i> View Details</a>
                </div>

            </div>
        }

    </div>

</div>


<style>
    body {
        font-family: inherit !important;
        background-color: #0b0b0b;
        color: #e2e8f0;
    }

    .jobsearch-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 30px;
    }

    /* HEADER */
    .page-title {
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        margin-bottom: 8px;
    }

    .page-subtitle {
        color: #94a3b8;
        font-size: 15px;
        margin-top: -8px;
        margin-bottom: 30px;
    }

    /* SEARCH BAR */
    .search-bar {
        display: flex;
        gap: 15px;
        margin-bottom: 40px;
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        padding: 24px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 12px 32px rgba(0,0,0,0.2);
    }

    .search-input {
        flex: 1;
        padding: 14px 18px;
        font-size: 15px;
        border-radius: 10px;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        transition: 0.3s;
        outline: none;
    }

        .search-input:focus {
            background: rgba(0, 0, 0, 0.4);
            border-color: #00FF88;
            box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.15);
        }

    .search-btn {
        background: #00FF88;
        color: #0b0b0b;
        border: none;
        padding: 12px 28px;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
    }

        .search-btn:hover {
            background: #00DF77;
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 6px 20px rgba(0, 255, 136, 0.35);
        }

    /* JOB CARDS */
    .jobs-wrapper {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .job-card {
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 24px 28px;
        border-radius: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .job-info {
        flex: 1;
        padding-right: 20px;
    }

        .job-card:hover {
            border-color: rgba(0, 255, 136, 0.3);
            box-shadow: 0 16px 40px rgba(0, 255, 136, 0.1);
            transform: translateY(-4px);
            background: rgba(255, 255, 255, 0.02);
        }

    .job-title {
        font-size: 20px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 8px;
        letter-spacing: -0.2px;
    }

    .job-desc {
        font-size: 14.5px;
        color: #94a3b8;
        margin-bottom: 0;
        max-width: 600px;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* BUTTON */
    .view-btn {
        background: transparent;
        color: #00FF88;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 10px;
        font-size: 14.5px;
        font-weight: 600;
        border: 1px solid rgba(0, 255, 136, 0.4);
        transition: 0.3s;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .view-btn:hover {
            background: rgba(0, 255, 136, 0.15);
            border-color: #00FF88;
            box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
            color: #00FF88;
            transform: translateY(-2px);
            text-decoration: none;
        }
</style>
