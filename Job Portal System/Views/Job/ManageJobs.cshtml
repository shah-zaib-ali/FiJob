@model List<Job_Portal_System.JOB>
@{
    ViewBag.Title = "Manage Jobs";
    Layout = "~/Views/Shared/_EmployeerDashboard.cshtml";
}

<style>
    /* Page Title */
    .page-title {
        color: #fff;
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 30px;
        text-align: center;
        letter-spacing: -0.5px;
    }

    /* Action Button */
    .btn-new-job {
        background: #00FF88;
        color: #0B0B0B;
        padding: 12px 28px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 30px;
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
    }

        .btn-new-job:hover {
            background: #00DF77;
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 6px 20px rgba(0, 255, 136, 0.35);
            color: #0B0B0B;
            text-decoration: none;
        }

    /* Table Card */
    .table-card {
        width: 100%;
        margin: auto;
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.2);
        border: 1px solid rgba(255, 255, 255, 0.08);
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 14.5px;
        color: #E2E8F0;
    }

    thead th {
        background: rgba(0, 0, 0, 0.4);
        color: #94A3B8;
        padding: 16px 18px;
        text-align: left;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    thead th:first-child { border-radius: 12px 0 0 0; }
    thead th:last-child { border-radius: 0 12px 0 0; }

    tbody td {
        padding: 16px 18px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        vertical-align: middle;
    }

    tbody tr:hover td {
        background: rgba(255, 255, 255, 0.02);
    }

    tbody tr:last-child td { border-bottom: none; }

    /* Action Buttons inside table */
    .btn-action {
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        margin-right: 6px;
        margin-bottom: 6px;
        text-decoration: none;
        transition: 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #fff;
    }

    .btn-action-edit {
        background: transparent;
        border: 1px solid #F59E0B;
        color: #F59E0B;
    }

        .btn-action-edit:hover {
            background: rgba(245, 158, 11, 0.1);
            color: #F59E0B;
            transform: translateY(-1px);
        }

    .btn-action-delete {
        background: transparent;
        border: 1px solid rgba(239, 68, 68, 0.5);
        color: #EF4444;
    }

        .btn-action-delete:hover {
            background: rgba(239, 68, 68, 0.1);
            border-color: #EF4444;
            color: #EF4444;
            transform: translateY(-1px);
        }

    .btn-action-view {
        background: transparent;
        border: 1px solid #00FF88;
        color: #00FF88;
    }

        .btn-action-view:hover {
            background: rgba(0, 255, 136, 0.1);
            color: #00FF88;
            border-color: #00FF88;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(0, 255, 136, 0.15);
        }
        
    .btn-action-details {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #E2E8F0;
    }

        .btn-action-details:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            transform: translateY(-1px);
        }

    /* Status Badges */
    .status-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 11px;
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-open {
        background: rgba(0, 255, 136, 0.1);
        color: #00FF88;
        border: 1px solid rgba(0, 255, 136, 0.2);
    }

    .status-closed {
        background: rgba(239, 68, 68, 0.1);
        color: #EF4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .status-pending {
        background: rgba(245, 158, 11, 0.1);
        color: #F59E0B;
        border: 1px solid rgba(245, 158, 11, 0.2);
    }
</style>

<div class="page-title">Manage Jobs</div>

<div class="text-center">
    <a href="@Url.Action("PostJob", "Job")" class="btn-new-job"><i class="fa-solid fa-plus"></i> Post New Job</a>
</div>

<div class="table-card">
    <table>
        <thead>
            <tr>
                <th>Job Title</th>
                <th>Location</th>
                <th>Job Type</th>
                <th>Posted On</th>
                <th>Expiry Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var job in Model)
            {
                string statusClass = job.status.ToLower() == "open" ? "status-open"
                                   : job.status.ToLower() == "closed" ? "status-closed"
                                   : "status-pending";

                <tr>
                    <td>@job.job_title</td>
                    <td>@job.location</td>
                    <td>@job.job_type</td>
                    <td>@(job.posted_date.HasValue ? job.posted_date.Value.ToString("dd-MM-yyyy") : "-")</td>
                    <td>@(job.expiry_date.HasValue ? job.expiry_date.Value.ToString("dd-MM-yyyy") : "-")</td>
                    <td>
                        <span class="status-badge @statusClass">@job.status</span>
                    </td>
                    <td>
                        <a href="@Url.Action("JobDetails", "Job", new { id = job.job_id })" class="btn-action btn-action-details" title="Preview Live Job Details" target="_blank">
                            <i class="fa-solid fa-file-lines"></i> Preview
                        </a>
                        <a href="@Url.Action("EditJob", "Job", new { id = job.job_id })" class="btn-action btn-action-edit">
                            <i class="fa-solid fa-pen-to-square"></i> Edit
                        </a>
                        <a href="@Url.Action("JobApplications", "Application", new { jobId = job.job_id })" class="btn-action btn-action-view" title="Manage Applications received for this Job">
                            <i class="fa-solid fa-users"></i> Applicants (@job.APPLICATIONS.Count())
                        </a>
                        <a href="@Url.Action("DeleteJob", "Job", new { id = job.job_id })" class="btn-action btn-action-delete" style="margin-top: 5px;" onclick="return confirm('Are you sure you want to permanently delete this job posting?');">
                            <i class="fa-solid fa-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
