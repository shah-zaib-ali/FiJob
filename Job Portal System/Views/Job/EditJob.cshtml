@model Job_Portal_System.ViewModel.JobEditViewModel

@{
    ViewBag.Title = "Edit Job";
    Layout = "~/Views/Shared/_EmployeerDashboard.cshtml";
}

<h2>Edit Job</h2>

<!-- ✅ MAIN EDIT JOB FORM -->
@using (Html.BeginForm("Edit", "Job", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    @* Hidden fields ko simple rakhen bina @ ke *@
    @Html.HiddenFor(m => m.Job.job_id)
    @Html.HiddenFor(m => m.Job.employer_id)
    @Html.HiddenFor(m => m.Job.posted_date)
    @Html.HiddenFor(m => m.Job.status)

    <div class="form-group">
        @Html.LabelFor(m => @Model.Job.job_title, "Job Title")
        @Html.TextBoxFor(m => @Model.Job.job_title, new { @class = "form-control", placeholder = "Enter Job Title" })
        @Html.ValidationMessageFor(m => @Model.Job.job_title, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => @Model.Job.job_description, "Job Description")
        @Html.TextAreaFor(m => @Model.Job.job_description, new { @class = "form-control", rows = 4, placeholder = "Enter Job Description" })
        @Html.ValidationMessageFor(m => @Model.Job.job_description, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => @Model.Job.requirements, "Job Requirments")
        @Html.TextAreaFor(m => @Model.Job.requirements, new { @class = "form-control", rows = 3, placeholder = "Enter Requirements" })
        @Html.ValidationMessageFor(m => @Model.Job.requirements, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => @Model.Job.location, "Job Location")
        @Html.TextBoxFor(m => @Model.Job.location, new { @class = "form-control", placeholder = "Location" })
        @Html.ValidationMessageFor(m => @Model.Job.location, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => @Model.Job.salary_range, "Salary Range")
        @Html.TextBoxFor(m => @Model.Job.salary_range, new { @class = "form-control", placeholder = "Salary (e.g., 50k-70k)" })
        @Html.ValidationMessageFor(m => m.Job.salary_range, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => @Model.Job.job_type, "Job Type")
        @Html.DropDownListFor(m => m.Job.job_type,
        new SelectList(new[]
        {
            new { Value = "Full-Time", Text = "Full-Time" },
            new { Value = "Part-Time", Text = "Part-Time" },
            new { Value = "Remote", Text = "Remote" },
            new { Value = "Internship", Text = "Internship" }
        }, "Value", "Text", Model.Job.job_type),
        "--- Select Job Type ---",
        new { @class = "form-control" })
        @Html.ValidationMessageFor(m => @Model.Job.job_type, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => @Model.Job.expiry_date, "Last Date to Apply")
        @Html.TextBoxFor(m => @Model.Job.expiry_date, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
        @Html.ValidationMessageFor(m => @Model.Job.expiry_date, "", new { @class = "text-danger" })
    </div>

    <!-- ❌ REMOVE ADD SKILL FORM FROM HERE -->

    <button type="submit" class="btn btn-primary">Update Job</button>
    <a href="@Url.Action("ManageJobs", "Employeer")" class="btn btn-secondary">Cancel</a>
}

<!-- ✅ ADD SKILL FORM (NOW SEPARATE - OUTSIDE MAIN FORM) -->
<div class="add-skill-box">
    @using (Html.BeginForm("AddSkill", "Job", FormMethod.Post, new { @class = "skill-form" }))
    {
        <input name="SkillName" class="skill-input" placeholder="Enter a new skill..." required />
        <input type="hidden" name="current_job_id" value="@Model.Job.job_id" />
        <button class="skill-add-btn" type="submit">Add Skill</button>
    }
</div>

<!-- ✅ SKILLS DISPLAY -->
<div class="skills-section">
    <h4 class="section-title">Your Added Skills</h4>
    <div class="skills-tags-wrapper">
        @foreach (var item in Model.Emp_job_skills)
        {
            <div class="skill-tag-box">
                <span class="skill-text">@item.skillName</span>
                <a href="/Job/DeleteSkill?skillId=@item.SkillID&jobId=@Model.Job.job_id" class="skill-delete-btn">✕</a>
            </div>
        }
    </div>
</div>

<style>
    .skills-tags-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .skill-tag-box {
        display: flex;
        align-items: center;
        background: white;
        border: 1px solid #dbeafe;
        padding: 8px 14px;
        border-radius: 25px;
        gap: 10px;
        transition: 0.2s;
    }

        .skill-tag-box:hover {
            border-color: #002e7f;
            background: #f0f6ff;
        }

    .skill-text {
        font-size: 14px;
        font-weight: 500;
        color: #002e7f;
    }

    .skill-delete-btn {
        font-size: 13px;
        color: #ef4444;
        padding: 2px 6px;
        border-radius: 50%;
        text-decoration: none;
        font-weight: bold;
        transition: 0.2s;
    }

        .skill-delete-btn:hover {
            background: #fee2e2;
            color: #b91c1c;
        }
</style>