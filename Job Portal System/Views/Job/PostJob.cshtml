@model Job_Portal_System.ViewModel.JobViewModel
@{
    ViewBag.Title = "Post a Job";
    Layout = "~/Views/Shared/_EmployeerDashboard.cshtml";
}

<style>
    /* Page Title */
    .page-title {
        color: #fff;
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 30px;
        text-align: center;
        letter-spacing: -0.5px;
    }

    .form-group .hint {
        display: block;
        font-size: 12px;
        color: #94A3B8;
        margin-top: 5px;
        flex-basis: 100%;
        margin-left: 180px; /* Label ki width ke barabar */
    }

    .skills-container {
        display: flex;
        flex-wrap: wrap;
        flex: 1;
    }

    /* Form Card */
    .form-card {
        max-width: 900px;
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        margin: auto;
        padding: 40px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 12px 32px rgba(0,0,0,0.2);
    }

    .form-group {
        margin-bottom: 24px;
        display: flex;
        align-items: flex-start;
    }

        .form-group label {
            width: 180px;
            font-weight: 600;
            color: #94A3B8;
            padding-top: 10px;
            text-transform: uppercase;
            font-size: 13.5px;
            letter-spacing: 0.8px;
        }

        .form-group .form-control {
            flex: 1;
            border-radius: 10px;
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            padding: 12px 16px;
            font-size: 15px;
            transition: 0.3s;
        }

        .form-group .form-control:focus {
            background: rgba(0, 0, 0, 0.4);
            border-color: #00FF88;
            box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.15);
            outline: none;
        }

        .form-group textarea.form-control {
            resize: vertical;
        }

    .btn-submit, .btn-cancel {
        padding: 14px 32px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: none;
        cursor: pointer;
        margin-right: 12px;
    }

    .btn-submit {
        background: #00FF88;
        color: #0B0B0B;
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
    }

        .btn-submit:hover {
            background: #00DF77;
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 6px 20px rgba(0, 255, 136, 0.35);
            color: #0B0B0B;
        }

    .btn-cancel {
        background: transparent;
        color: #E2E8F0;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

        .btn-cancel:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            border-color: rgba(255, 255, 255, 0.4);
            transform: translateY(-2px);
        }
        
    /* Date Input Specifics */
    ::-webkit-calendar-picker-indicator {
        filter: invert(1);
    }
</style>

<div class="page-title">Post a Job</div>

<div class="form-card">
    @using (Html.BeginForm("PostJob", "Job", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="form-group">
            @Html.LabelFor(m => m.JobTitle)
            @Html.TextBoxFor(m => m.JobTitle, new { @class = "form-control" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.JobDescription)
            @Html.TextAreaFor(m => m.JobDescription, new { @class = "form-control", rows = 5 })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Requirements)
            @Html.TextAreaFor(m => m.Requirements, new { @class = "form-control", rows = 3 })
        </div>

        @* --- Naya Skills Section --- *@
        <div class="form-group" style="flex-wrap: wrap;">
            <label>Required Skills</label>
            <div class="skills-container">
                @Html.TextBoxFor(m => m.RequiredSkills, new { @class = "form-control", list = "skillsList", placeholder = "e.g. C#, SQL, Python" })
                <datalist id="skillsList">
                    @* Agar aapke pas ViewBag mein skills hain toh yahan show hongi *@
                    @if (ViewBag.ExistingSkills != null)
                    {
                        foreach (var skill in ViewBag.ExistingSkills)
                        {
                            <option value="@skill"></option>
                        }
                    }
                </datalist>
            </div>
            <span class="hint">Separate multiple skills with commas (,). New skills will be added automatically.</span>
        </div>
        @* --------------------------- *@

        <div class="form-group">
            @Html.LabelFor(m => m.Location)
            @Html.TextBoxFor(m => m.Location, new { @class = "form-control" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.SalaryRange)
            @Html.TextBoxFor(m => m.SalaryRange, new { @class = "form-control" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.JobType)
            @Html.TextBoxFor(m => m.JobType, new { @class = "form-control" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.ExpiryDate)
            @Html.TextBoxFor(m => m.ExpiryDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
        </div>

        <div class="text-center mt-4">
            <input type="submit" value="Post Job" class="btn-submit" />
            <a href="@Url.Action("ManageJobs", "Job")" class="btn-cancel">Cancel</a>
        </div>
    }
</div>
