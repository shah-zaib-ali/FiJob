@model Job_Portal_System.ViewModel.JobDetailsViewModel

@{
    ViewBag.Title = "Job Details";

    var role = Session["UserRole"] != null ? Session["UserRole"].ToString() : "";
    if (role == "Employer")
    {
        Layout = "~/Views/Shared/_Layout.cshtml"; // Removed JobSeekerDashboard layout
    }
    else
    {
        Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
    }

    var userId = Session["UserId"] != null ? (int)Session["UserId"] : 0;
    var hasApplied = ViewBag.HasApplied != null && (bool)ViewBag.HasApplied;
}

<div class="job-details-container">

    <h2 class="job-title">@Model.Job.job_title</h2>
    <p class="job-subtitle">Explore job insights, requirements and apply instantly.</p>

    <div class="main-content-grid">
        <div class="job-details-card">
            <div class="details-section">
                <h4 class="section-heading">Job Description</h4>
                <p class="description-text">@Model.Job.job_description</p>

                <div class="info-grid">
                    <div class="info-item">
                        <span class="detail-label">Location:</span>
                        <span class="detail-value">@Model.Job.location</span>
                    </div>
                    <div class="info-item">
                        <span class="detail-label">Salary:</span>
                        <span class="detail-value">@Model.Job.salary_range</span>
                    </div>
                    <div class="info-item">
                        <span class="detail-label">Job Type:</span>
                        <span class="detail-value">@Model.Job.job_type</span>
                    </div>
                </div>
            </div>

            <hr class="divider" />

            @if (role != "Employer")
            {
                <div class="job-actions">
                    @if (hasApplied)
                    {
                        <button class="btn-disabled" disabled>Already Applied</button>
                        <a class="save-btn" href="@Url.Action("SaveJob", "SavedJobs", new { jobId = Model.Job.job_id })">Save Job</a>
                        <a class="msg-btn" href="@Url.Action("Index", "Chat", new { receiverId = Model.Job.employer_id })">
                            <i class="fa-solid fa-comment"></i> Message Employer
                        </a>
                    }

                    @if (userId > 0 && !hasApplied)
                    {
                        <a class="apply-btn" href="@Url.Action("Apply", "Application", new { jobId = Model.Job.job_id })">Apply Now</a>
                        <a class="save-btn" href="@Url.Action("SaveJob", "SavedJobs", new { jobId = Model.Job.job_id })">Save Job</a>
                    }
                </div>
            }
        </div>

        <div class="employer-card">
            <h4 class="employer-title">About Employer</h4>
            <div class="employer-details">
                <div class="employer-avatar">
                   @if (!string.IsNullOrEmpty(Model.Employerr_detail.companyLogo)) {
                        <img src="@Model.Employerr_detail.companyLogo" alt="Company Logo" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                   } else {
                       <i class="fa-solid fa-building"></i>
                   }
                </div>
                <div class="employer-text">
                    <p class="emp-name">@Model.Employerr_detail.company_name</p>
                    <p class="emp-email">@Model.Employer.email</p>
                </div>
            </div>
            <p class="trust-badge"><i class="fas fa-check-circle"></i> Verified Employer</p>
        </div>
    </div>
</div>

<style>
    body {
        font-family: inherit !important;
        background-color: #0b0b0b;
        color: #e2e8f0;
    }

    .job-details-container {
        max-width: 1100px;
        margin: auto;
        padding: 30px;
    }

    .main-content-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 25px;
    }

    .job-title {
        font-size: 32px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 5px;
        letter-spacing: -0.5px;
    }

    .job-subtitle {
        color: #94a3b8;
        font-size: 14.5px;
        margin-bottom: 30px;
    }

    /* MAIN CARD */
    .job-details-card {
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        padding: 35px;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0px 10px 25px rgba(0,0,0,0.3);
    }

    .section-heading {
        font-size: 18px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 15px;
    }

    .description-text {
        line-height: 1.7;
        color: #e2e8f0;
        margin-bottom: 25px;
        font-size: 15px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .detail-label {
        font-weight: 600;
        color: #94a3b8;
        display: block;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 4px;
    }

    .detail-value {
        color: #00FF88;
        font-size: 16px;
        font-weight: 500;
    }

    /* EMPLOYER CARD */
    .employer-card {
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        padding: 25px;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        align-self: start;
        text-align: center;
        box-shadow: 0px 10px 25px rgba(0,0,0,0.3);
    }

    .employer-title {
        font-size: 16px;
        font-weight: 600;
        color: #fff;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .employer-avatar {
        width: 60px;
        height: 60px;
        background: rgba(0, 255, 136, 0.1);
        color: #00FF88;
        border: 1px solid rgba(0, 255, 136, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-weight: 700;
        font-size: 24px;
    }

    .emp-name {
        font-weight: 700;
        color: #fff;
        margin-bottom: 4px;
        font-size: 16px;
    }

    .emp-email {
        font-size: 13.5px;
        color: #94a3b8;
    }

    .trust-badge {
        margin-top: 20px;
        font-size: 12px;
        color: #00FF88;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    /* ACTIONS */
    .job-actions {
        display: flex;
        gap: 15px;
        margin-top: 10px;
        flex-wrap: wrap;
    }

    .msg-btn {
        background: transparent;
        border: 1px solid rgba(0, 255, 136, 0.4);
        padding: 14px 25px;
        border-radius: 12px;
        color: #00FF88;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
        text-align: center;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .msg-btn:hover {
            background: rgba(0, 255, 136, 0.1);
            color: #00FF88;
            border-color: #00FF88;
            transform: translateY(-2px);
            text-decoration: none;
            box-shadow: 0 4px 12px rgba(0, 255, 136, 0.15);
        }

    .apply-btn {
        background: #00FF88;
        padding: 14px 30px;
        border-radius: 12px;
        color: #0b0b0b;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
        flex: 1;
        text-align: center;
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
    }

        .apply-btn:hover {
            background: #00DF77;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(0, 255, 136, 0.3);
            color: #0b0b0b;
            text-decoration: none;
        }

    .save-btn {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 14px 25px;
        border-radius: 12px;
        color: #e2e8f0;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
    }

        .save-btn:hover {
            background: rgba(255,255,255,0.1);
            color: #fff;
            text-decoration: none;
            transform: translateY(-2px);
        }
        
    .btn-disabled {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 14px 25px;
        border-radius: 12px;
        color: #64748b;
        font-weight: 600;
        cursor: not-allowed;
    }

    .divider {
        margin: 30px 0;
        border: 0;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .main-content-grid {
            grid-template-columns: 1fr;
        }
        .job-actions {
            flex-direction: column;
        }
        .apply-btn, .save-btn, .msg-btn, .btn-disabled {
            width: 100%;
            justify-content: center;
        }
    }
</style>