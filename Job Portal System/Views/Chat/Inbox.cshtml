@model IEnumerable<Job_Portal_System.USER>
@{
    ViewBag.Title = "Inbox";
    // Layout is dynamically set in ChatController.cs
}

<style>
    body {
        font-family: inherit !important;
        background-color: #0b0b0b;
        color: #e2e8f0;
    }
    
    .inbox-container {
        max-width: 850px;
        margin: auto;
    }

    .inbox-title {
        font-size: 26px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 12px;
        letter-spacing: -0.5px;
    }
    
    .no-chats {
        background: rgba(18, 18, 18, 0.6);
        padding: 40px;
        text-align: center;
        border-radius: 16px;
        color: #94a3b8;
        font-size: 15px;
        border: 1px dashed rgba(255, 255, 255, 0.08);
    }
    
    .no-chats i {
        font-size: 24px;
        color: rgba(255, 255, 255, 0.2);
        margin-bottom: 12px;
        display: block;
    }

    .conversation-card {
        display: flex;
        align-items: flex-start;
        padding: 18px 24px;
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        text-decoration: none;
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 8px 24px rgba(0,0,0,0.2);
        margin-bottom: 16px;
    }

    .conversation-card:hover {
        background: rgba(0, 255, 136, 0.05);
        border-color: rgba(255, 255, 255, 0.15);
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3);
        text-decoration: none;
    }

    .avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(0, 255, 136, 0.1);
        color: #00FF88;
        border: 1px solid rgba(0, 255, 136, 0.2);
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 20px;
        margin-right: 20px;
        flex-shrink: 0;
    }

    .chat-body {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 48px;
    }

    .user-name {
        font-size: 15px;
        font-weight: 500;
        color: #fff;
        line-height: 1.5;
        margin-bottom: 6px;
    }

    .user-subtext {
        font-size: 13px;
        color: #94a3b8;
        font-weight: 500;
    }

    .btn-chat {
        display: flex;
        align-items: center;
        justify-content: center;
        padding-left: 20px;
        min-height: 48px;
    }
    
    .btn-chat span {
        background: transparent;
        color: #00FF88;
        border: 1px solid rgba(0, 255, 136, 0.4);
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 13.5px;
        font-weight: 600;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
        cursor: pointer;
    }

    .conversation-card:hover .btn-chat span {
        background: rgba(0, 255, 136, 0.15);
        border-color: #00FF88;
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
        transform: translateY(-1px);
    }
</style>

<div class="inbox-container">
    <h2 class="inbox-title">Direct Messages</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="no-chats">
            <i class="fa-regular fa-paper-plane"></i>
            <p>You have no active conversations yet.</p>
        </div>
    }
    else
    {
        <div class="conversation-list">
            @foreach (var user in Model)
            {
                <a href="@Url.Action("Index", "Chat", new { receiverId = user.UserId })" class="conversation-card">
                    <div class="avatar">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    <div class="chat-body">
                        <div class="user-name"><strong>@user.full_name</strong> - Connect</div>
                        <div class="user-subtext">Tap to open secure conversation</div>
                    </div>
                    <div class="btn-chat">
                        <span>Open Chat <i class="fa-solid fa-arrow-right-long"></i></span>
                    </div>
                </a>
            }
        </div>
    }
</div>

