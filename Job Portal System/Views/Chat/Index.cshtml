@{
    ViewBag.Title = "Index";
    Layout = (string)ViewBag.Layout ?? "~/Views/Shared/_EmployeerDashboard.cshtml";
}

<style>
    .chat-card {
        max-width: 800px;
        margin: 20px auto;
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        display: flex;
        flex-direction: column;
        height: 70vh;
    }

    .chat-header {
        padding: 20px;
        border-bottom: 2px solid #e6edf7;
        color: #002E7F;
        font-weight: 700;
        font-size: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
    }
    
    .chat-back-btn {
        background: #f1f5f9;
        color: #002E7F;
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: 0.2s;
    }
    
    .chat-back-btn:hover {
        background: #e2e8f0;
        color: #002E7F;
        text-decoration: none;
    }

    #chatWindow {
        flex-grow: 1;
        overflow-y: auto;
        padding: 20px;
        background: #f8fbff;
    }

    .msg-box {
        margin-bottom: 15px;
        max-width: 70%;
        padding: 10px 15px;
        border-radius: 12px;
        font-size: 14px;
        position: relative;
    }

    .msg-sent {
        background: #002E7F;
        color: white;
        align-self: flex-end;
        margin-left: auto;
        border-bottom-right-radius: 2px;
    }

    .msg-received {
        background: white;
        color: #333;
        border: 1px solid #e6edf7;
        align-self: flex-start;
        border-bottom-left-radius: 2px;
    }

    .chat-footer {
        padding: 20px;
        border-top: 2px solid #e6edf7;
        display: flex;
        gap: 10px;
    }

    .msg-input {
        flex-grow: 1;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 10px;
        outline: none;
    }

    .btn-send {
        background: #002E7F;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }
    
    .btn-send:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }
</style>

<div class="chat-card">
    <div class="chat-header">
        <a href="@Url.Action("Inbox", "Chat")" class="chat-back-btn" title="Back to Inbox">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        Chat with @ViewBag.ReceiverName
    </div>

    <div id="chatWindow">
        @foreach (var msg in Model)
        {
            var isMe = msg.SenderID == (int)Session["UserId"];
            <div class="msg-box @(isMe ? "msg-sent" : "msg-received")">
                @msg.MessageText
                <div style="font-size: 10px; opacity: 0.7; margin-top: 5px;">
                    @msg.Timestamp.ToString("hh:mm tt")
                </div>
            </div>
        }
    </div>

    <div class="chat-footer">
        <input type="hidden" id="receiverId" value="@ViewBag.ReceiverID" />
        <input type="hidden" id="senderId" value="@Session["UserId"]" />

        <input type="text" id="messageInput" class="msg-input" placeholder="Write a message..." autocomplete="off" />
        <button id="btnSend" class="btn-send">Send</button>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/jquery.signalR-2.4.3.min.js"></script>
    <script src="~/signalr/hubs"></script>

    <script>
        $(function () {
            var chat = $.connection.chatHub;
            var $chatWin = $('#chatWindow');

            // Scroll to bottom initially
            $chatWin.scrollTop($chatWin[0].scrollHeight);

            // Client-side function jo Hub call karega
            chat.client.addNewMessageToPage = function (sId, rId, message) {
                var currentUserId = $('#senderId').val();
                var targetUserId = $('#receiverId').val();

                // Sirf tab dikhana agar message in do logon ke darmiyan ho
                if ((sId == currentUserId && rId == targetUserId) || (sId == targetUserId && rId == currentUserId)) {
                    var isMe = (sId == currentUserId);
                    var msgHtml = '<div class="msg-box ' + (isMe ? 'msg-sent' : 'msg-received') + '">' +
                        message +
                        '</div>';

                    $chatWin.append(msgHtml);
                    $chatWin.scrollTop($chatWin[0].scrollHeight);
                }
            };

            $.connection.hub.start().done(function () {
                $('#btnSend').click(function () {
                    sendMessage();
                });

                $('#messageInput').keypress(function (e) {
                    if (e.which == 13) {
                        sendMessage();
                    }
                });

                function sendMessage() {
                    var msg = $('#messageInput').val();
                    var sId = $('#senderId').val();
                    var rId = $('#receiverId').val();

                    if (msg.trim() !== "") {
                        chat.server.sendMessage(sId, rId, msg);
                        $('#messageInput').val('').focus();
                    }
                }
            });
        });
    </script>
}

