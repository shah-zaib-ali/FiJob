@model IEnumerable<Job_Portal_System.Message>
@{
    ViewBag.Title = "Chat";
    // Layout logic handled via Controller dynamically
}

<style>
    body {
        font-family: inherit !important;
        background-color: #0b0b0b;
        color: #e2e8f0;
    }
    
    /* Overlay for floating box */
    .chat-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(4px);
        z-index: 1040;
        display: flex;
        justify-content: center;
        align-items: center;
    }
    
    .chat-container {
        width: 100%;
        max-width: 600px;
        height: 80vh;
        max-height: 800px;
        background: rgba(18, 18, 18, 0.85);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.6);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: scaleUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    
    @@keyframes scaleUp {
        from { opacity: 0; transform: scale(0.95) translateY(20px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    .chat-header {
        background: rgba(18, 18, 18, 0.95);
        color: #fff;
        padding: 20px 24px;
        font-size: 18px;
        font-weight: 700;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        align-items: center;
        justify-content: space-between;
        letter-spacing: -0.3px;
        z-index: 10;
    }
    
    .header-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    
    .header-left i {
        color: #00FF88;
        font-size: 20px;
    }
    
    .btn-close-chat {
        background: transparent;
        border: none;
        color: #94a3b8;
        font-size: 20px;
        cursor: pointer;
        transition: 0.2s;
        text-decoration: none;
    }
    
    .btn-close-chat:hover {
        color: #EF4444;
        transform: scale(1.1);
    }

    .chat-window {
        flex-grow: 1;
        padding: 24px;
        overflow-y: auto;
        background: rgba(0, 0, 0, 0.2);
        display: flex;
        flex-direction: column;
        gap: 16px;
        /* Scrollbar styles */
        scrollbar-width: thin;
        scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
    }
    
    .chat-window::-webkit-scrollbar {
        width: 6px;
    }
    .chat-window::-webkit-scrollbar-thumb {
        background-color: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }

    .msg-box {
        max-width: 70%;
        padding: 12px 18px;
        border-radius: 16px;
        font-size: 14.5px;
        line-height: 1.5;
        border: 1px solid transparent;
        animation: smoothSlideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    
    @@keyframes smoothSlideUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .msg-sent {
        align-self: flex-end;
        background: rgba(0, 255, 136, 0.1);
        color: #fff;
        border-color: rgba(0, 255, 136, 0.2);
        border-bottom-right-radius: 4px;
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.05);
    }

    .msg-received {
        align-self: flex-start;
        background: rgba(255, 255, 255, 0.05);
        color: #E2E8F0;
        border-color: rgba(255, 255, 255, 0.1);
        border-bottom-left-radius: 4px;
    }

    .time-stamp {
        display: block;
        font-size: 11px;
        color: rgba(255,255,255,0.4);
        margin-top: 6px;
        text-align: right;
    }

    .chat-input-area {
        display: flex;
        padding: 20px;
        background: rgba(18, 18, 18, 0.95);
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        gap: 12px;
    }

    .msg-input {
        flex-grow: 1;
        padding: 14px 20px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 30px;
        font-size: 15px;
        background: rgba(0, 0, 0, 0.4);
        color: #fff;
        outline: none;
        transition: 0.3s;
    }

    .msg-input:focus {
        border-color: #00FF88;
        box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.15);
    }

    .btn-send {
        background: #00FF88;
        color: #0b0b0b;
        border: none;
        padding: 0 28px;
        border-radius: 30px;
        font-weight: 600;
        font-size: 15px;
        cursor: pointer;
        transition: 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
    }

    .btn-send:hover {
        background: #00DF77;
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 6px 16px rgba(0, 255, 136, 0.3);
    }
</style>

<div class="chat-overlay">
    <div class="chat-container">
        <div class="chat-header">
            <div class="header-left">
                <i class="fa-regular fa-comment-dots"></i> 
                @ViewBag.ReceiverName
            </div>
            <a href="@Url.Action("Inbox", "Chat")" class="btn-close-chat"><i class="fa-solid fa-xmark"></i></a>
        </div>

        <!-- Receiver ki ID hum server ko batane ke liye hidden field use karenge -->
        <input type="hidden" id="receiverId" value="@ViewBag.ReceiverId" />
        <input type="hidden" id="senderId" value="@Session["UserId"]" />

        <div class="chat-window" id="chatWindow">
            @foreach (var msg in Model)
            {
                var isMe = msg.SenderID == (int)Session["UserId"];
                <div class="msg-box @(isMe ? "msg-sent" : "msg-received")">
                    @msg.MessageText
                    <div class="time-stamp">
                        @(msg.Timestamp.HasValue ? msg.Timestamp.Value.ToString("hh:mm tt") : "")
                    </div>
                </div>
            }
        </div>

        <div class="chat-input-area">
            <input type="text" id="messageInput" class="msg-input" placeholder="Write a message..." autocomplete="off" />
            <button id="btnSend" class="btn-send">Send</button>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/jquery.signalR-2.4.3.min.js"></script>
    <script src="~/signalr/hubs"></script>

    <script>
        $(function () {
            var chat = $.connection.chatHub;
            var $chatWin = $('#chatWindow');

            // Scroll to bottom initially
            $chatWin.scrollTop($chatWin[0].scrollHeight);

            // Client-side function jo Hub call karega
            chat.client.addNewMessageToPage = function (sId, rId, message) {
                var currentUserId = $('#senderId').val();
                var targetUserId = $('#receiverId').val();

                // Sirf tab dikhana agar message in do logon ke darmiyan ho
                if ((sId == currentUserId && rId == targetUserId) || (sId == targetUserId && rId == currentUserId)) {
                    var isMe = (sId == currentUserId);
                    var msgHtml = '<div class="msg-box ' + (isMe ? 'msg-sent' : 'msg-received') + '">' +
                        message +
                        '</div>';

                    $chatWin.append(msgHtml);
                    $chatWin.scrollTop($chatWin[0].scrollHeight);
                }
            };

            $.connection.hub.start().done(function () {
                $('#btnSend').click(function () {
                    sendMessage();
                });

                $('#messageInput').keypress(function (e) {
                    if (e.which == 13) {
                        sendMessage();
                    }
                });

                function sendMessage() {
                    var msg = $('#messageInput').val();
                    var sId = $('#senderId').val();
                    var rId = $('#receiverId').val();

                    if (msg.trim() !== "") {
                        chat.server.sendMessage(sId, rId, msg);
                        $('#messageInput').val('').focus();
                    }
                }
            });
        });
    </script>
}

