@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Job Seeker Dashboard</title>
    <!-- Add Favicon -->
    <link rel="icon" type="image/png" href="~/Images/CompanyLogos/fijob_logo.png">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Alegreya:ital,wght@0,400..900;1,400..900&family=Bodoni+Moda:ital,opsz,wght@0,6..96,400..900;1,6..96,400..900&family=Fjalla+One&family=Google+Sans+Flex:opsz,wght@6..144,1..1000&family=Gravitas+One&family=Josefin+Sans:ital,wght@0,100..700;1,100..700&family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Oswald:wght@200..700&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Public+Sans:ital,wght@0,100..900;1,100..900&family=Quicksand:wght@300..700&family=Roboto+Condensed:ital,wght@0,561;1,561&family=Urbanist:ital,wght@0,100..900;1,100..900&display=swap');
        /* ========== RESET & BASE ========== */
        *, *::before, *::after { box-sizing: border-box; }

        :root {
            --navy:        rgba(18, 18, 18, 0.85); /* Topbar base */
            --navy-mid:    #1A1A1A;
            --blue:        #00FF88; /* Changed to Neon Green */
            --blue-light:  #00DF77;
            --blue-pale:   rgba(0, 255, 136, 0.08); /* Hover effects */
            --blue-border: rgba(0, 255, 136, 0.3);
            --surface:     rgba(18, 18, 18, 0.95); /* Panels/Sidebar */
            --bg:          #0B0B0B; /* Deep Black Background */
            --border:      rgba(255, 255, 255, 0.08); /* Subtle glass borders */
            --text-primary: #FFFFFF;
            --text-second:  #E2E8F0;
            --text-muted:   #94A3B8;
            --green:        #00FF88;
            --green-pale:   rgba(0, 255, 136, 0.1);
            --amber:        #F59E0B;
            --amber-pale:   rgba(245, 158, 11, 0.1);
            --red:          #EF4444;
            --red-pale:     rgba(239, 68, 68, 0.1);
            --radius-sm:    8px;
            --radius-md:    12px;
            --radius-lg:    16px;
            --sidebar-w:    240px;
            --topbar-h:     68px;
            --transition:   0.3s ease;
        }

        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            font-size: 14.5px;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        /* ========== TOPBAR ========== */
        .hh-topbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: var(--topbar-h);
            background: var(--navy);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            display: flex;
            align-items: center;
            padding: 0 24px;
            z-index: 1000;
            border-bottom: 1px solid var(--border);
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.6);
        }

        /* Logo */
        .hh-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            flex-shrink: 0;
            width: var(--sidebar-w);
        }

        .hh-logo-mark {
            width: 36px;
            height: 36px;
            background: var(--blue);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 0 12px rgba(0, 255, 136, 0.4);
        }

        .hh-logo-mark svg {
            width: 20px;
            height: 20px;
            fill: #0B0B0B; /* Dark logo icon */
        }

        .hh-logo-name {
            font-size: 20px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 0.5px;
        }

        .hh-logo-name span {
            color: var(--blue);
        }

        /* Search bar */
        .hh-search {
            flex: 1;
            max-width: 520px;
            margin: 0 32px;
        }

        .hh-search-inner {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 20px;
            display: flex;
            align-items: center;
            padding: 0 16px;
            height: 42px;
            transition: var(--transition);
        }

        .hh-search-inner:focus-within {
            background: rgba(255, 255, 255, 0.08);
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.15);
        }

        .hh-search-inner i {
            color: var(--text-muted);
            font-size: 14px;
            margin-right: 10px;
            flex-shrink: 0;
            transition: color var(--transition);
        }
        
        .hh-search-inner:focus-within i {
            color: var(--blue);
        }

        .hh-search-inner input {
            background: transparent;
            border: none;
            outline: none;
            color: var(--text-primary);
            font-size: 14px;
            font-family: inherit;
            width: 100%;
        }

        .hh-search-inner input::placeholder {
            color: rgba(255, 255, 255, 0.3);
            font-weight: 400;
        }

        /* Topbar right */
        .hh-topbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .hh-icon-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-second);
            font-size: 16px;
            cursor: pointer;
            transition: var(--transition);
            position: relative;
            text-decoration: none;
            background: transparent;
            border: 1px solid transparent;
        }

        .hh-icon-btn:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: var(--border);
            color: var(--text-primary);
            transform: translateY(-2px);
        }

        .hh-icon-btn .badge-dot {
            position: absolute;
            top: 6px;
            right: 6px;
            width: 10px;
            height: 10px;
            background: var(--blue);
            border-radius: 50%;
            border: 2px solid #0B0B0B;
            box-shadow: 0 0 8px rgba(0, 255, 136, 0.6);
        }

        /* Avatar / dropdown */
        .hh-avatar-wrap {
            position: relative;
        }

        .hh-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: var(--blue);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0B0B0B;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            border: 2px solid transparent;
            transition: var(--transition);
            user-select: none;
            box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
        }

        .hh-avatar:hover {
            transform: scale(1.05);
            box-shadow: 0 6px 16px rgba(0, 255, 136, 0.35);
        }

        .hh-dropdown {
            position: absolute;
            top: calc(100% + 14px);
            right: 0;
            width: 220px;
            background: rgba(18, 18, 18, 0.95);
            backdrop-filter: blur(16px);
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
            padding: 8px;
            opacity: 0;
            pointer-events: none;
            transform: translateY(-10px);
            transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
            z-index: 999;
        }

        .hh-avatar-wrap:focus-within .hh-dropdown,
        .hh-avatar-wrap.open .hh-dropdown {
            opacity: 1;
            pointer-events: all;
            transform: translateY(0);
        }

        .hh-dropdown a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: var(--radius-sm);
            color: var(--text-second);
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            transition: var(--transition);
        }

        .hh-dropdown a:hover {
            background: var(--blue-pale);
            color: var(--text-primary);
        }

        .hh-dropdown a i {
            width: 18px;
            text-align: center;
            color: var(--text-muted);
            font-size: 14px;
            transition: var(--transition);
        }
        
        .hh-dropdown a:hover i {
            color: var(--blue);
            transform: scale(1.1);
        }

        .hh-dropdown .logout-link {
            color: var(--red);
        }

        .hh-dropdown .logout-link i {
            color: var(--red);
        }
        
        .hh-dropdown .logout-link:hover {
            background: var(--red-pale);
            color: var(--red);
        }

        /* ========== SIDEBAR ========== */
        .hh-sidebar {
            position: fixed;
            top: var(--topbar-h);
            left: 0;
            bottom: 0;
            width: var(--sidebar-w);
            background: var(--surface);
            backdrop-filter: blur(12px);
            border-right: 1px solid var(--border);
            padding: 24px 12px;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            z-index: 900;
            scrollbar-width: none;
        }

        .hh-sidebar::-webkit-scrollbar { display: none; }

        .hh-nav-section {
            margin-bottom: 24px;
        }

        .hh-nav-label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--text-muted);
            padding: 0 14px 10px;
        }

        .hh-nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: var(--radius-sm);
            color: var(--text-second);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: var(--transition);
            position: relative;
            margin-bottom: 2px;
        }

        .hh-nav-link i {
            width: 20px;
            text-align: center;
            font-size: 16px;
            flex-shrink: 0;
            color: var(--text-muted);
            transition: var(--transition);
        }

        .hh-nav-link:hover {
            background: var(--blue-pale);
            color: var(--blue);
        }

        .hh-nav-link:hover i {
            color: var(--blue);
            transform: scale(1.1);
        }

        .hh-nav-link.active {
            background: var(--blue-pale);
            color: var(--blue);
            font-weight: 600;
        }

        .hh-nav-link.active i {
            color: var(--blue);
            text-shadow: 0 0 12px rgba(0, 255, 136, 0.6);
        }

        .hh-nav-link.active::before {
            content: '';
            position: absolute;
            left: -12px;
            top: 20%;
            height: 60%;
            width: 4px;
            background: var(--blue);
            border-radius: 0 4px 4px 0;
            box-shadow: 0 0 12px rgba(0, 255, 136, 0.8);
        }

        .hh-nav-badge {
            margin-left: auto;
            background: var(--blue);
            color: #0B0B0B;
            font-size: 11px;
            font-weight: 700;
            padding: 3px 8px;
            border-radius: 20px;
            min-width: 22px;
            text-align: center;
            line-height: 1.4;
            box-shadow: 0 2px 8px rgba(0, 255, 136, 0.3);
        }

        .hh-nav-badge.red {
            background: transparent;
            border: 1px solid var(--red);
            color: var(--red);
            box-shadow: none;
        }

        .hh-sidebar-footer {
            margin-top: auto;
            padding-top: 16px;
            border-top: 1px solid var(--border);
        }

        /* ========== MAIN CONTENT ========== */
        .hh-content {
            margin-left: var(--sidebar-w);
            margin-top: var(--topbar-h);
            min-height: calc(100vh - var(--topbar-h));
            padding: 32px 32px 80px;
        }

        /* ========== PAGE COMPONENTS ========== */

        /* Page header */
        .hh-page-header {
            margin-bottom: 32px;
        }

        .hh-page-header h1 {
            font-size: 26px;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0 0 6px;
            letter-spacing: -0.5px;
        }

        .hh-page-header p {
            color: var(--text-muted);
            font-size: 15px;
            margin: 0;
        }

        /* Cards */
        .hh-card {
            background: rgba(18, 18, 18, 0.6);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 28px;
            margin-bottom: 24px;
            box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
            transition: var(--transition);
        }
        
        .hh-card:hover {
            border-color: rgba(255, 255, 255, 0.15);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.3);
        }

        .hh-card-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0 0 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Buttons */
        .hh-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            text-decoration: none;
            border: 1px solid transparent;
            line-height: 1.5;
            white-space: nowrap;
            outline: none;
        }

        .hh-btn-primary {
            background: var(--blue);
            color: #0B0B0B;
            border-color: var(--blue);
            box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
        }

        .hh-btn-primary:hover {
            background: var(--blue-light);
            color: #0B0B0B;
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 6px 20px rgba(0, 255, 136, 0.35);
        }

        .hh-btn-outline {
            background: transparent;
            color: var(--blue);
            border-color: var(--blue-border);
        }

        .hh-btn-outline:hover {
            background: var(--blue-pale);
            color: var(--blue);
            border-color: var(--blue);
            transform: translateY(-2px);
        }

        .hh-btn-ghost {
            background: transparent;
            color: var(--text-second);
            border-color: transparent;
        }

        .hh-btn-ghost:hover {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-primary);
            border-color: var(--border);
        }

        .hh-btn-danger {
            background: transparent;
            color: var(--red);
            border-color: rgba(239, 68, 68, 0.3);
        }

        .hh-btn-danger:hover {
            background: var(--red-pale);
            border-color: var(--red);
            color: var(--red);
            transform: translateY(-2px);
        }

        .hh-btn-success {
            background: var(--green);
            color: #0B0B0B;
            border-color: var(--green);
            box-shadow: 0 4px 12px rgba(0, 255, 136, 0.15);
        }

        .hh-btn-success:hover {
            background: #00DF77;
            border-color: #00DF77;
            color: #0B0B0B;
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 6px 16px rgba(0, 255, 136, 0.3);
        }

        .hh-btn-sm {
            padding: 6px 14px;
            font-size: 13px;
        }

        .hh-btn-lg {
            padding: 12px 28px;
            font-size: 15.5px;
        }

        /* Tables & the rest ... */
        .hh-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-top: 10px;
        }

        .hh-table thead th {
            background: var(--navy-mid);
            color: var(--text-muted);
            font-weight: 600;
            font-size: 12.5px;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            padding: 14px 18px;
            border-bottom: 1px solid var(--border);
        }

        .hh-table thead th:first-child {
            border-radius: var(--radius-sm) 0 0 0;
        }

        .hh-table thead th:last-child {
            border-radius: 0 var(--radius-sm) 0 0;
        }

        .hh-table tbody td {
            padding: 16px 18px;
            border-bottom: 1px solid var(--border);
            color: var(--text-second);
            font-size: 14.5px;
            vertical-align: middle;
            transition: var(--transition);
        }

        .hh-table tbody tr:hover td {
            background: rgba(255, 255, 255, 0.02);
            color: var(--text-primary);
        }
        
        .hh-table tbody tr:last-child td { border-bottom: none; }

        /* Form elements */
        .hh-form-group {
            margin-bottom: 22px;
        }

        .hh-label {
            display: block;
            font-size: 14px;
            font-weight: 500;
            color: var(--text-second);
            margin-bottom: 8px;
        }

        .hh-input, .hh-select, .hh-textarea {
            width: 100%;
            height: 46px;
            padding: 0 16px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: var(--radius-sm);
            font-size: 14.5px;
            font-family: inherit;
            color: var(--text-primary);
            background: rgba(0, 0, 0, 0.2);
            transition: all 0.3s ease;
            outline: none;
        }

        .hh-textarea {
            height: auto;
            padding: 14px 16px;
            resize: vertical;
        }

        .hh-input:focus, .hh-select:focus, .hh-textarea:focus {
            background: rgba(0, 0, 0, 0.4);
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.15);
        }

        .hh-input::placeholder { color: var(--text-muted); }
        
        /* Stat row */
        .hh-stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }

        .hh-stat-card {
            background: rgba(18, 18, 18, 0.6);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 22px;
            backdrop-filter: blur(10px);
            transition: var(--transition);
        }
        
        .hh-stat-card:hover {
            border-color: rgba(255, 255, 255, 0.15);
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.4);
        }

        .hh-stat-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .hh-stat-label i {
            color: var(--blue);
        }

        .hh-stat-value {
            font-size: 32px;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1;
            letter-spacing: -1px;
        }

        /* Profile snippet in sidebar bottom */
        .hh-sidebar-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            border-radius: var(--radius-sm);
            transition: var(--transition);
            cursor: pointer;
            text-decoration: none;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--border);
        }

        .hh-sidebar-profile:hover { 
            background: rgba(255, 255, 255, 0.05); 
            border-color: rgba(255, 255, 255, 0.15);
        }

        .hh-sidebar-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: var(--blue);
            color: #0B0B0B;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            flex-shrink: 0;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 255, 136, 0.2);
        }

        .hh-sidebar-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .hh-sidebar-user-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
            line-height: 1.3;
        }

        .hh-sidebar-user-role {
            font-size: 12px;
            color: var(--blue);
            font-weight: 500;
        }

        /* ========== FOOTER ========== */
        .hh-footer {
            position: fixed;
            bottom: 0;
            left: var(--sidebar-w);
            right: 0;
            height: 44px;
            background: var(--surface);
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: var(--text-muted);
            z-index: 800;
        }

        .hh-footer a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color var(--transition);
        }

        .hh-footer a:hover { color: var(--blue); }

        /* ========== MOBILE SIDEBAR TOGGLE ========== */
        .hh-menu-toggle {
            display: none;
            background: transparent;
            border: none;
            color: rgba(255,255,255,0.8);
            font-size: 20px;
            cursor: pointer;
            padding: 0 10px 0 0;
        }

        /* ========== BREADCRUMB ========== */
        .hh-breadcrumb {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12.5px;
            color: var(--text-muted);
            margin-bottom: 16px;
        }

        .hh-breadcrumb a {
            color: var(--blue);
            text-decoration: none;
        }

        .hh-breadcrumb a:hover { text-decoration: underline; }

        .hh-breadcrumb span { color: var(--text-muted); }

        /* ========== SIDEBAR OVERLAY (MOBILE) ========== */
        .hh-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.4);
            z-index: 850;
            backdrop-filter: blur(2px);
        }

        /* ========== DIVIDER ========== */
        .hh-divider {
            height: 1px;
            background: var(--border);
            margin: 20px 0;
        }

        /* ========== RESPONSIVE ========== */
        @@media (max-width: 900px) {
            .hh-menu-toggle { display: flex; }

            .hh-sidebar {
                transform: translateX(-100%);
                transition: transform 0.22s ease;
                z-index: 1001;
            }

            .hh-sidebar.open {
                transform: translateX(0);
                box-shadow: 4px 0 20px rgba(0,0,0,0.12);
            }

            .hh-overlay.open { display: block; }

            .hh-content {
                margin-left: 0;
            }

            .hh-footer {
                left: 0;
            }

            .hh-search {
                display: none;
            }
        }

        @@media (max-width: 600px) {
            .hh-content { padding: 16px 14px 70px; }
            .hh-stats-row { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>

    <!-- ===== HEADER ===== -->
    <header class="hh-topbar">
        <button class="hh-menu-toggle" id="menuToggle" aria-label="Open menu">
            <i class="fa-solid fa-bars"></i>
        </button>

        <a class="hh-logo" href="/JobSeeker/Dashboard">
            <div class="hh-logo-mark">
                <!-- Briefcase icon SVG -->
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M20 7h-4V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zm-10-2h4v2h-4V5zm2 11a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm6-4H6v-1l2-2h8l2 2v1z" />
                </svg>
            </div>
            <span class="hh-logo-name">Fi<span>Job</span></span>
        </a>

        <!-- Search bar -->
        <div class="hh-search">
            <div class="hh-search-inner">
                <i class="fa-solid fa-search"></i>
                <input type="text" placeholder="Search jobs, companies, skills..." />
            </div>
        </div>

        <div class="hh-topbar-right">
            <a href="/Chat/Inbox" class="hh-icon-btn" title="Messages">
                <i class="fa-solid fa-envelope"></i>
                <span class="badge-dot" id="topbarMsgBadge" style="display:none;"></span>
            </a>
            <div class="hh-avatar-wrap">
                <div class="hh-avatar" tabindex="0" style="overflow:hidden;">
                    @if (Session["ProfilePicturePath"] != null && !string.IsNullOrEmpty(Session["ProfilePicturePath"].ToString()))
                    {
                        <img src="@Session["ProfilePicturePath"].ToString()" alt="Profile" style="width:100%; height:100%; object-fit:cover;"/>
                    }
                    else
                    {
                        @(Session["UserName"] != null ? Session["UserName"].ToString().Substring(0, 2).ToUpper() : "U")
                    }
                </div>
                <div class="hh-dropdown">
                    <a href="/JobSeeker/ViewProfile" class="d-flex align-items-center">
                        <i class="fa-solid fa-user"></i>
                        <span>Profile</span>
                    </a>
                    <a href="/Application/MyApplications" class="d-flex align-items-center">
                        <i class="fa-solid fa-briefcase"></i>
                        <span>My Applications</span>
                    </a>
                    <a href="/SavedJobs/SavedJobsList" class="d-flex align-items-center">
                        <i class="fa-solid fa-heart"></i>
                        <span>Saved Jobs</span>
                    </a>
                    <div class="hh-dropdown-divider"></div>
                    <a href="/Account/Logout" class="d-flex align-items-center logout-link">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <span>Logout</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- ===== SIDEBAR OVERLAY (Mobile) ===== -->
    <div class="hh-overlay" id="sidebarOverlay"></div>

    <!-- ===== SIDEBAR ===== -->
    <aside class="hh-sidebar" id="sidebar">

        <nav>
            <div class="hh-nav-section">
                <div class="hh-nav-label">Account</div>
                <a href="/JobSeeker/ViewProfile" class="hh-nav-link">
                    <i class="fa-solid fa-user"></i>
                    My Profile
                </a>
                <a href="/JobSeeker/ManageSkills" class="hh-nav-link">
                    <i class="fa-solid fa-screwdriver-wrench"></i>
                    My Skills
                </a>
            </div>

            <div class="hh-nav-section">
                <div class="hh-nav-label">Jobs</div>
                <a href="/Job/BrowseJobs" class="hh-nav-link">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    Browse Jobs
                </a>
                <a href="/Job/DiscoverJobs" class="hh-nav-link">
                    <i class="fa-solid fa-compass"></i>
                    Discover
                </a>
                <a href="/SavedJobs/SavedJobsList" class="hh-nav-link">
                    <i class="fa-solid fa-bookmark"></i>
                    Saved Jobs
                </a>
                <a href="/Application/MyApplications" class="hh-nav-link">
                    <i class="fa-solid fa-file-circle-check"></i>
                    My Applications
                </a>
            </div>

            <div class="hh-nav-section">
                <div class="hh-nav-label">Communication</div>
                <a href="@Url.Action("Inbox", "Chat")" class="hh-nav-link">
                    <i class="fa-solid fa-envelope"></i>
                    Messages
                    <span class="hh-nav-badge" id="sidebarMsgBadge" style="display:none; background-color: #00FF88; color: #0b0b0b;">0</span>
                </a>
                <a href="/Notification/JobSeekerNotifications" class="hh-nav-link">
                    <i class="fa-solid fa-bell"></i>
                    Notifications
                    <span class="hh-nav-badge red" id="sidebarNotifBadge" style="display:none; background-color: #FF4D4D; color: white;">0</span>
                </a>
            </div>
        </nav>

        <!-- Sidebar Bottom Profile -->
        <div class="hh-sidebar-footer">
            <a href="/JobSeeker/ViewProfile" class="hh-sidebar-profile">
                <div class="hh-sidebar-avatar">
                    @if (Session["ProfilePicturePath"] != null && !string.IsNullOrEmpty(Session["ProfilePicturePath"].ToString()))
                    {
                        <img src="@Session["ProfilePicturePath"].ToString()" alt="Profile" style="width:100%; height:100%; object-fit:cover;" />
                    }
                    else
                    {
                        @(Session["UserName"] != null ? Session["UserName"].ToString().Substring(0, 2).ToUpper() : "U")
                    }
                </div>
                <div>
                    <div class="hh-sidebar-user-name">@(Session["UserName"] != null ? Session["UserName"].ToString() : "User")</div>
                    <div class="hh-sidebar-user-role">Job Seeker</div>
                </div>
            </a>
        </div>
    </aside>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="hh-content">
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="hh-footer">
        &copy; @DateTime.Now.Year FiJob &nbsp;·&nbsp;
        <a href="#">Privacy</a> &nbsp;·&nbsp;
        <a href="#">Terms</a> &nbsp;·&nbsp;
        <a href="#">Help</a>
    </footer>

    <!-- Main Script Files -->
    <script src="~/Scripts/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SignalR for real-time notifications -->
    <script src="~/Scripts/jquery.signalR-2.4.3.min.js"></script>
    <script src="~/signalr/hubs"></script>

    <!-- Custom scripts -->
    <script>
        $(function () {
            // SignalR Connection
            var chat = $.connection.chatHub;
            
            // Function to load actual unread counts on initial load
            function fetchInitialBadgeCounts() {
                $.ajax({
                    url: '/Chat/GetUnreadCounts',
                    type: 'GET',
                    success: function (data) {
                        if (data.messagesCount > 0) {
                            $('#sidebarMsgBadge').text(data.messagesCount).css('display', 'inline-block');
                            $('#topbarMsgBadge').show();
                        } else {
                            $('#sidebarMsgBadge').hide();
                            $('#topbarMsgBadge').hide();
                        }
                        
                        if (data.notificationsCount > 0) {
                            $('#sidebarNotifBadge').text(data.notificationsCount).css('display', 'inline-block');
                        } else {
                            $('#sidebarNotifBadge').hide();
                        }
                    }
                });
            }
            
            chat.client.updateMessageBadge = function (receiverId) {
                var currentUserId = @((Session["UserId"] != null) ? Session["UserId"].ToString() : "0");
                if (receiverId == currentUserId) {
                    var badge = $('#sidebarMsgBadge');
                    var currentVal = parseInt(badge.text()) || 0;
                    currentVal += 1;
                    badge.text(currentVal).css('display', 'inline-block');
                    $('#topbarMsgBadge').show();
                }
            };
            
            chat.client.updateNotificationBadge = function (receiverId) {
                var currentUserId = @((Session["UserId"] != null) ? Session["UserId"].ToString() : "0");
                if (receiverId == currentUserId) {
                    var badge = $('#sidebarNotifBadge');
                    var currentVal = parseInt(badge.text()) || 0;
                    currentVal += 1;
                    badge.text(currentVal).css('display', 'inline-block');
                }
            };

            $.connection.hub.start().done(function () {
                console.log("Connected to Real-time Hub");
                fetchInitialBadgeCounts();
            });
        });

        // Sidebar toggle
        const menuToggle = document.getElementById('menuToggle');
        const sidebar = document.querySelector('.hh-sidebar');
        const overlay = document.querySelector('.hh-overlay');

        menuToggle.addEventListener('click', () => {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('open');
        });

        overlay.addEventListener('click', () => {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
        });

        // Close dropdowns when clicking outside
        document.addEventListener('click', (e) => {
            const avatarWrap = document.querySelector('.hh-avatar-wrap');
            const dropdown = document.querySelector('.hh-dropdown');

            if (!avatarWrap.contains(e.target)) {
                dropdown.classList.remove('show');
            }
        });

        // Show/hide dropdown on avatar click
        document.querySelector('.hh-avatar').addEventListener('click', function() {
            this.nextElementSibling.classList.toggle('show');
        });

        // Initialize tooltips
        const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        const tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    </script>
    
    @RenderSection("scripts", required: false)
</body>
</html>
