@model IEnumerable<Job_Portal_System.ViewModel.JobSeekerApplicationViewModel>

@{
    ViewBag.Title = "My Applications";
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Inter', sans-serif;
        background: #f5f7fb;
    }

    .page-title {
        text-align: center;
        font-size: 30px;
        font-weight: 700;
        color: #1a73e8;
        margin-bottom: 30px;
    }

    .apps-container {
        max-width: 1100px;
        margin: auto;
    }

    .app-card {
        background: white;
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.06);
        padding: 22px;
        margin-bottom: 20px;
        transition: 0.3s;
    }

        .app-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 28px rgba(0,0,0,0.08);
        }

    .app-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
    }

    .job-title {
        font-size: 18px;
        font-weight: 700;
        color: #222;
    }

    .company-name {
        color: #666;
        font-size: 14px;
        margin-top: 4px;
    }

    .applied-date {
        font-size: 13px;
        color: #888;
        margin-top: 6px;
    }

    .status-badge {
        padding: 7px 14px;
        border-radius: 25px;
        font-size: 12px;
        font-weight: 600;
    }

    .status-approved {
        background: #E3F7EF;
        color: #0B7A48;
    }

    .status-pending {
        background: #FFF7E0;
        color: #C48A00;
    }

    .status-rejected {
        background: #FDEAEA;
        color: #C62828;
    }

    .interview-section {
        margin-top: 18px;
        background: #f8fbff;
        border-left: 4px solid #1a73e8;
        border-radius: 12px;
        padding: 14px 16px;
    }

    .interview-title {
        font-weight: 600;
        color: #1a73e8;
        margin-bottom: 10px;
    }

    .interview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
        gap: 12px;
        font-size: 13px;
    }

    .interview-item strong {
        display: block;
        color: #333;
        margin-bottom: 3px;
    }

    .btn-row {
        margin-top: 18px;
        text-align: right;
    }

    .btn-withdraw {
        padding: 8px 16px;
        border-radius: 8px;
        background: #fff0f0;
        color: #d32f2f !important;
        border: 1px solid #d32f2f;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
    }

        .btn-withdraw:hover {
            background: #d32f2f;
            color: white !important;
        }

    .no-apps {
        background: white;
        text-align: center;
        padding: 60px;
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    }

        .no-apps img {
            width: 90px;
            margin-bottom: 15px;
        }

    .feedback-section {
        margin-top: 15px;
        background: #fff5f5;
        border-left: 4px solid #c62828;
        border-radius: 12px;
        padding: 14px 16px;
    }

    .feedback-title {
        font-weight: 600;
        color: #c62828;
        font-size: 14px;
        margin-bottom: 5px;
    }

    .feedback-text {
        font-size: 13px;
        color: #444;
        font-style: italic;
    }
</style>

<h2 class="page-title">My Applications</h2>

@if (!Model.Any())
{
    <div class="no-apps">
        <img src="https://cdn-icons-png.flaticon.com/512/4076/4076508.png" />
        <p>You have not applied to any jobs yet.</p>
    </div>
}
else
{
    <div class="apps-container">

        @foreach (var app in Model)
        {
            string statusClass = "";
            if (app.Status == "Approved")
            {
                statusClass = "status-approved";
            }
            else if (app.Status == "REJECTED")
            {
                statusClass = "status-rejected";
            }
            else
            {
                statusClass = "status-pending";
            }

            <div class="app-card">
                <div class="app-top">
                    <div>
                        <div class="job-title">@app.JobTitle</div>
                        <div class="company-name">@app.CompanyName</div>
                        <div class="applied-date">
                            Applied on @(app.AppliedDate.HasValue ? app.AppliedDate.Value.ToString("dd MMM yyyy") : "--")
                        </div>
                    </div>
                    <span class="status-badge @statusClass">@app.Status</span>
                </div>

                @* --- CASE 1: Interview Scheduled (Sirf tab dikhayein jab data ho) --- *@
                @if (app.Status == "Interview Scheduled" && app.InterviewDate.HasValue)
                {
                    <div class="interview-section">
                        <div class="interview-title"><i class="fas fa-calendar-check"></i> Interview Scheduled</div>
                        <div class="interview-grid">
                            <div class="interview-item">
                                <strong>Date & Time</strong>
                                @app.InterviewDate.Value.ToString("dd MMM yyyy hh:mm tt")
                            </div>
                            <div class="interview-item">
                                <strong>Location / Link</strong>
                                @if (app.InterviewLocation.StartsWith("http"))
                                {
                                    <a href="@app.InterviewLocation" target="_blank">Join Meeting</a>
                                }
                                else
                                {
                                    @app.InterviewLocation
                                }
                            </div>
                            <div class="interview-item">
                                <strong>Instructions</strong>
                                @(string.IsNullOrEmpty(app.InterviewNotes) ? "No special instructions." : app.InterviewNotes)
                            </div>
                        </div>
                    </div>
                }

                @* --- CASE 2: Rejected with Feedback --- *@
                @if (app.Status != null && app.Status.Equals("REJECTED", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="feedback-section">
                        <div class="feedback-title">Employer Feedback</div>
                        <div class="feedback-text">
                            @(string.IsNullOrEmpty(app.RejectionFeedback) ? "Thank you for your interest. Unfortunately, the company has decided to move forward with other candidates." : app.RejectionFeedback)
                        </div>
                    </div>
                }

                <div class="btn-row">
                    @if (app.Status == "Pending")
                    {
                        <a class="btn-withdraw"
                           href="@Url.Action("Withdraw", "Application", new { id = app.ApplicationId })"
                           onclick="return confirm('Are you sure you want to withdraw this application?')">
                            Withdraw Application
                        </a>


                    }
                </div>
                <a href="@Url.Action("Index", "Chat", new { receiverId = app.EmployerId })"
                   class="btn-action" style="background: #1a73e8; color:white; padding: 8px 16px; border-radius: 8px; text-decoration:none;">
                    Chat with Employer
                </a>
            </div>
        }

    </div>
}