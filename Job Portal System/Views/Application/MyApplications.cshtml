@model IEnumerable<Job_Portal_System.ViewModel.JobSeekerApplicationViewModel>

@{
    ViewBag.Title = "My Applications";
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
}

<style>
    .page-header {
        text-align: center;
        margin-bottom: 30px;
    }
    
    .page-header h2 {
        font-size: 26px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 6px;
        letter-spacing: -0.5px;
    }
    
    .page-header p {
        color: #94A3B8;
        font-size: 15px;
    }

    .table-card {
        max-width: 1000px;
        margin: 0 auto;
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.2);
        overflow: hidden;
    }

    .table-card table {
        width: 100%;
        border-collapse: collapse;
    }

    .table-card thead th {
        background: rgba(255, 255, 255, 0.02);
        color: #94A3B8;
        font-size: 12.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        padding: 16px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        text-align: left;
    }

    .table-card tbody td {
        padding: 18px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        vertical-align: middle;
        font-size: 14.5px;
        color: #E2E8F0;
        transition: 0.2s ease;
    }

    .table-card tbody tr:last-child td {
        border-bottom: none;
    }

    .table-card tbody tr:hover td {
        background: rgba(255, 255, 255, 0.03);
    }

    .job-title-td strong {
        display: block;
        font-size: 16px;
        color: #fff;
        margin-bottom: 4px;
        font-weight: 600;
        letter-spacing: -0.3px;
    }

    .job-title-td span {
        font-size: 13px;
        color: #94A3B8;
    }

    .status-badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .status-approved {
        background: rgba(0, 255, 136, 0.1);
        color: #00FF88;
        border: 1px solid rgba(0, 255, 136, 0.2);
    }

    .status-rejected {
        background: rgba(239, 68, 68, 0.1);
        color: #EF4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .status-pending {
        background: rgba(245, 158, 11, 0.1);
        color: #F59E0B;
        border: 1px solid rgba(245, 158, 11, 0.2);
    }

    .status-scheduled {
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
        border: 1px solid rgba(59, 130, 246, 0.2);
        cursor: pointer;
        transition: 0.3s;
    }
    
    .status-scheduled:hover {
        background: rgba(59, 130, 246, 0.2);
        border-color: #3b82f6;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
        transform: translateY(-1px);
    }

    .btn-withdraw {
        color: #EF4444;
        background: rgba(239, 68, 68, 0.05);
        padding: 6px 14px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        border: 1px solid rgba(239, 68, 68, 0.2);
        transition: 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        display: inline-block;
    }

    .btn-withdraw:hover {
        background: rgba(239, 68, 68, 0.15);
        border-color: #EF4444;
        text-decoration: none;
        color: #EF4444;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.15);
    }

    .empty-state {
        text-align: center;
        padding: 50px 20px;
        color: #94A3B8;
        font-size: 15px;
    }

    /* Modal Styling */
    .modal-content {
        background: rgba(18, 18, 18, 0.95);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        color: #fff;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
    }

    .modal-header {
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px 16px 0 0;
        padding: 20px 24px;
    }
    
    .modal-header .close {
        color: #fff;
        text-shadow: none;
        opacity: 0.5;
        transition: 0.3s;
    }
    .modal-header .close:hover {
        opacity: 1;
        color: #EF4444;
    }

    .modal-title {
        color: #fff;
        font-weight: 700;
        font-size: 18px;
    }
    
    .modal-body {
        padding: 24px;
    }

    .detail-row {
        margin-bottom: 12px;
        display: flex;
        font-size: 14.5px;
    }

    .detail-label {
        width: 130px;
        font-weight: 600;
        color: #94A3B8;
        flex-shrink: 0;
    }
    
    .detail-value {
        color: #E2E8F0;
    }
    
    .modal-footer {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding: 16px 24px;
    }
    
    .modal-btn-close {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 8px 16px;
        border-radius: 8px;
        font-weight: 500;
        transition: 0.3s;
    }
    
    .modal-btn-close:hover {
        background: rgba(255, 255, 255, 0.05);
    }
</style>

<div class="page-header">
    <h2>My Applications</h2>
    <p>Track the status of your job applications</p>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <img src="https://cdn-icons-png.flaticon.com/512/4076/4076508.png" alt="No Applications" style="width: 80px; margin-bottom: 16px;">
        <p style="font-size: 16px; font-weight: 500;">You haven't applied to any jobs yet.</p>
        <p>Explore job listings and apply to start your career journey.</p>
    </div>
}
else
{
    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th style="width: 40%;">Job Details</th>
                    <th style="width: 20%;">Company</th>
                    <th style="width: 20%;">Status</th>
                    <th style="width: 20%;" class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var app in Model)
                {
                    <tr>
                        <td class="job-title-td">
                            <strong>@app.JobTitle</strong>
                            <span>Applied on @(app.AppliedDate.HasValue ? app.AppliedDate.Value.ToString("dd MMM yyyy") : "--")</span>
                        </td>
                        <td>
                            <span>@app.CompanyName</span>
                        </td>
                        <td>
                            @{
                                string statusClass = "";
                                if (app.Status == "Approved")
                                {
                                    statusClass = "status-approved";
                                }
                                else if (app.Status == "REJECTED")
                                {
                                    statusClass = "status-rejected";
                                }
                                else
                                {
                                    statusClass = "status-pending";
                                }
                            }
                            <span class="status-badge @statusClass">@app.Status</span>
                        </td>
                        <td class="text-center">
                            <a href="@Url.Action("Details", "Application", new { id = app.ApplicationId })" class="btn btn-primary btn-sm" style="background-color: #1a73e8; border-color: #1a73e8; color: white;">
                                View Details
                            </a>
                            @if (app.Status == "Pending")
                            {
                                <a class="btn-withdraw"
                                   href="@Url.Action("Withdraw", "Application", new { id = app.ApplicationId })"
                                   onclick="return confirm('Are you sure you want to withdraw this application?')">
                                    Withdraw Application
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}