@model IEnumerable<Job_Portal_System.APPLICATION>

@{
    ViewBag.Title = "Applications";
    Layout = "~/Views/Shared/_EmployeerDashboard.cshtml";
}

<style>
    .page-header {
        text-align: center;
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-size: 26px;
            font-weight: 700;
            color: #fff;
            margin-bottom: 6px;
            letter-spacing: -0.5px;
        }

        .page-header p {
            color: #94A3B8;
            font-size: 15px;
        }

    .table-card {
        max-width: 1050px;
        margin: 0 auto;
        background: rgba(18, 18, 18, 0.6);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 12px 32px rgba(0,0,0,0.2);
        overflow: hidden;
    }

        .table-card table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .table-card thead th {
            background: rgba(255, 255, 255, 0.02);
            color: #94A3B8;
            font-size: 12.5px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            padding: 16px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            text-align: left;
        }

        .table-card tbody td {
            padding: 18px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            vertical-align: middle;
            font-size: 14.5px;
            color: #E2E8F0;
            transition: 0.2s ease;
        }

        .table-card tbody tr:last-child td {
            border-bottom: none;
        }

        .table-card tbody tr:hover td {
            background: rgba(255, 255, 255, 0.03);
        }

    .seeker-name {
        font-weight: 600;
        font-size: 15.5px;
        color: #fff;
        letter-spacing: -0.2px;
        margin-bottom: 4px;
    }

    .seeker-bio {
        font-size: 13px;
        color: #94A3B8;
        margin-top: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 180px;
    }

    .status-badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .status-approved {
        background: rgba(0, 255, 136, 0.1);
        color: #00FF88;
        border: 1px solid rgba(0, 255, 136, 0.2);
    }

    .status-rejected {
        background: rgba(239, 68, 68, 0.1);
        color: #EF4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .status-pending {
        background: rgba(245, 158, 11, 0.1);
        color: #F59E0B;
        border: 1px solid rgba(245, 158, 11, 0.2);
    }

    .status-scheduled {
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

    .resume-box {
        width: 54px;
        height: 64px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        color: #94A3B8;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    a.resume-box:hover {
        background: rgba(0, 255, 136, 0.05);
        color: #00FF88;
        border-color: #00FF88;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
        text-decoration: none;
    }

    .actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        border: 1px solid transparent;
        cursor: pointer;
        text-decoration: none;
        transition: 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        line-height: 1.4;
    }

        .btn-action:hover {
            transform: translateY(-1px);
            text-decoration: none;
        }

    .btn-approve {
        background: rgba(0, 255, 136, 0.05);
        color: #00FF88;
        border-color: rgba(0, 255, 136, 0.2);
    }
    
    .btn-approve:hover {
        background: rgba(0, 255, 136, 0.15);
        border-color: #00FF88;
        color: #00FF88;
        box-shadow: 0 4px 12px rgba(0, 255, 136, 0.2);
    }

    .btn-reject {
        background: rgba(239, 68, 68, 0.05);
        color: #EF4444;
        border-color: rgba(239, 68, 68, 0.2);
    }
    
    .btn-reject:hover {
        background: rgba(239, 68, 68, 0.15);
        border-color: #EF4444;
        color: #EF4444;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
    }

    .btn-schedule {
        background: rgba(59, 130, 246, 0.05);
        color: #3b82f6;
        border-color: rgba(59, 130, 246, 0.2);
    }
    
    .btn-schedule:hover {
        background: rgba(59, 130, 246, 0.15);
        border-color: #3b82f6;
        color: #3b82f6;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
    }

    .btn-message {
        background: rgba(168, 85, 247, 0.05);
        color: #a855f7;
        border-color: rgba(168, 85, 247, 0.2);
    }
    
    .btn-message:hover {
        background: rgba(168, 85, 247, 0.15);
        border-color: #a855f7;
        color: #a855f7;
        box-shadow: 0 4px 12px rgba(168, 85, 247, 0.2);
    }

    /* Modal */
    .modal-content {
        background: rgba(18, 18, 18, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 16px 40px rgba(0,0,0,0.5);
        color: #E2E8F0;
    }

    .modal-header {
        background: rgba(255, 255, 255, 0.02);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px 16px 0 0;
        padding: 20px 24px;
    }

        .modal-header .modal-title {
            font-size: 18px;
            font-weight: 700;
            color: #fff;
            margin: 0;
            letter-spacing: -0.3px;
        }

        .modal-header .close {
            color: #fff;
            opacity: 0.5;
            text-shadow: none;
            transition: 0.3s;
        }
        
        .modal-header .close:hover {
            color: #EF4444;
            opacity: 1;
        }

    .modal-body {
        padding: 24px;
    }

    .modal-footer {
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding: 16px 24px;
    }
    
    .modal-btn-cancel {
        background: transparent;
        color: #E2E8F0;
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 500;
        transition: 0.3s;
    }

    .modal-btn-cancel:hover {
        background: rgba(255, 255, 255, 0.05);
    }

    .form-group label {
        font-size: 13.5px;
        font-weight: 600;
        color: #CBD5E1;
        margin-bottom: 8px;
        display: block;
    }

    .form-control {
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(0, 0, 0, 0.2);
        color: #fff;
        font-size: 14.5px;
        padding: 12px 14px;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            background: rgba(0, 0, 0, 0.4);
            border-color: #00FF88;
            box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.15);
            color: #fff;
            outline: none;
        }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #94A3B8;
        font-size: 15px;
    }
</style>

<div class="page-header">
    <h2>Applications for: @ViewBag.JobTitle</h2>
    <p>@Model.Count() applicant(s) found</p>
</div>

@if (!Model.Any())
{
    <div class="table-card">
        <div class="empty-state">No applicants yet.</div>
    </div>
}
else
{
    <div class="table-card">
        <table>
            <colgroup>
                <col style="width:20%">
                <col style="width:9%">
                <col style="width:16%">
                <col style="width:12%">
                <col style="width:43%">
            </colgroup>
            <thead>
                <tr>
                    <th>Applicant</th>
                    <th>Resume</th>
                    <th>Status</th>
                    <th>Applied</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var app in Model)
                {
                    string statusClass = "status-pending";
                    string s = (app.status ?? "").ToLower();
                    if (s == "approved") { statusClass = "status-approved"; }
                    else if (s == "rejected") { statusClass = "status-rejected"; }
                    else if (s == "interview scheduled") { statusClass = "status-scheduled"; }

                    <tr>
                        <td>
                            <div class="seeker-name">@app.JOB_SEEKER_PROFILE.USER.full_name</div>
                            <div class="seeker-bio" title="@app.JOB_SEEKER_PROFILE.Bio">@app.JOB_SEEKER_PROFILE.Bio</div>
                        </td>

                        <td>
                            @if (!string.IsNullOrEmpty(app.JOB_SEEKER_PROFILE.resume_file))
                            {
                                <a href="@Url.Action("DownloadResume", "Employeer", new { seekerId = app.seeker_id })"
                                   class="resume-box" target="_blank" title="View Resume">PDF</a>
                            }
                            else
                            {
                                <div class="resume-box" style="cursor:default;">—</div>
                            }
                        </td>

                        <td>
                            <span class="status-badge @statusClass">@app.status</span>
                        </td>

                        <td style="color:#94A3B8;font-size:14px;">
                            @(app.applied_date.HasValue ? app.applied_date.Value.ToString("dd MMM yyyy") : "--")
                        </td>

                        <td>
                            <div class="actions">
                                <a href="@Url.Action("UpdateStatus", "Application", new { id = app.application_id, status = "APPROVED" })"
                                   class="btn-action btn-approve"><i class="fa-solid fa-check"></i> Approve</a>

                                <button class="btn-action btn-reject"
                                        onclick="rejectApplication(@app.application_id)">
                                    <i class="fa-solid fa-xmark"></i> Reject
                                </button>

                                <button class="btn-action btn-schedule"
                                        onclick="openScheduleModal(@app.application_id, '@app.JOB_SEEKER_PROFILE.USER.full_name')">
                                    <i class="fa-regular fa-calendar-plus"></i> Schedule
                                </button>

                                <a href="@Url.Action("Index", "Chat", new { receiverId = app.seeker_id })"
                                   class="btn-action btn-message"><i class="fa-regular fa-message"></i> Message</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- ===== SCHEDULE MODAL ===== -->
<div class="modal fade" id="scheduleModal" tabindex="-1" role="dialog" aria-labelledby="scheduleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="scheduleModalLabel">
                    Schedule Interview — <span id="modalSeekerName"></span>
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="modalAppId" />

                <div class="form-row">
                    <div class="form-group">
                        <label>Interview Type</label>
                        <select id="intType" class="form-control">
                            <option>Online</option>
                            <option>In-Person</option>
                            <option>Phone Call</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Interview Status</label>
                        <select id="intStatus" class="form-control">
                            <option>Scheduled</option>
                            <option>Rescheduled</option>
                            <option>Cancelled</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Date &amp; Time</label>
                    <input type="datetime-local" id="intDate" class="form-control" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Interviewer Name</label>
                        <input type="text" id="intInterviewer" class="form-control" placeholder="Full name" autocomplete="off" />
                    </div>
                    <div class="form-group">
                        <label>Interviewer Email</label>
                        <input type="email" id="intEmail" class="form-control" placeholder="email@company.com" autocomplete="off" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Location / Meeting Link</label>
                    <input type="text" id="intLocation" class="form-control" placeholder="e.g. Zoom link or office address" autocomplete="off" />
                </div>

                <div class="form-group">
                    <label>Instructions for Applicant</label>
                    <textarea id="intNotes" class="form-control" rows="2" placeholder="What should the candidate bring or prepare?"></textarea>
                </div>

                <div class="form-group">
                    <label>Internal Notes</label>
                    <textarea id="internalNotes" class="form-control" rows="2" placeholder="Private notes (not visible to applicant)"></textarea>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="modal-btn-cancel" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitSchedule()">Save Interview</button>
            </div>

        </div>
    </div>
</div>

<script>
    // ── Reject ──────────────────────────────────────────────
    function rejectApplication(appId) {
        var reason = prompt("Enter rejection reason (optional):");
        if (reason === null) return;

        $.post('/Employeer/RejectApplication', { id: appId, feedback: reason }, function (res) {
            if (res.success) {
                alert("Application rejected.");
                location.reload();
            } else {
                alert("Error: " + res.message);
            }
        });
    }

    // Compatibility helper for Bootstrap 4 (jQuery) and Bootstrap 5 (native)
    function showBootstrapModal(selector, options) {
        options = options || { backdrop: 'static', keyboard: false };

        // Attempt to use native Bootstrap 5 API first (since 5.3 is loaded heavily in the layout)
        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
            var el = document.querySelector(selector);
            if (el) {
                var modalInstance = bootstrap.Modal.getOrCreateInstance(el, options);
                modalInstance.show();
                return;
            }
        }

        // Fallback to jQuery
        if (typeof $ !== 'undefined' && $.fn && $.fn.modal) {
            var $el = $(selector);
            $el.modal(options);
            $el.modal('show');
            return;
        }

        console.warn('Bootstrap modal API not found; please ensure Bootstrap JS is loaded.');
    }

    // ── Open modal ──────────────────────────────────────────
    function openScheduleModal(appId, seekerName) {
        console.log("Opening schedule modal for appId: ", appId);
        $('#modalAppId').val(appId);
        $('#modalSeekerName').text(seekerName);

        // Reset fields
        $('#intType').val('Online');
        $('#intDate').val('');
        $('#intLocation').val('');
        $('#intInterviewer').val('');
        $('#intEmail').val('');
        $('#intNotes').val('');
        $('#internalNotes').val('');
        $('#intStatus').val('Scheduled');

        // Fetch existing interview if any
        $.get('/Employeer/GetInterview', { appId: appId }, function (data) {
            if (data) {
                $('#intType').val(data.interview_type);
                $('#intLocation').val(data.location_or_link);
                $('#intInterviewer').val(data.interviewer_name);
                $('#intEmail').val(data.interviewer_email);
                $('#intNotes').val(data.notes_for_seeker);
                $('#internalNotes').val(data.internal_notes);
                $('#intStatus').val(data.interview_status);

                // Parse the /Date(...)/ format from JSON.NET
                if (data.interview_date) {
                    var ms = parseInt(data.interview_date.replace(/\/Date\((\d+)\)\//, '$1'));
                    var dt = new Date(ms);
                    var pad = function (n) { return ("0" + n).slice(-2); };
                    $('#intDate').val(
                        dt.getFullYear() + "-" + pad(dt.getMonth() + 1) + "-" + pad(dt.getDate()) +
                        "T" + pad(dt.getHours()) + ":" + pad(dt.getMinutes())
                    );
                }
            }

            // Show modal using compatibility helper
            console.log("Showing modal element");
            showBootstrapModal('#scheduleModal', { backdrop: 'static', keyboard: false });
        }).fail(function(xhr) {
             console.error("Failed to get interview data", xhr);
             showBootstrapModal('#scheduleModal', { backdrop: 'static', keyboard: false });
        });
    }

    // ── Submit ──────────────────────────────────────────────
    function submitSchedule() {
        var dateVal = $('#intDate').val();
        var appId = $('#modalAppId').val();

        if (!dateVal) { alert("Please select a date and time."); return; }
        if (!appId) { alert("Error: Application ID missing."); return; }

        var payload = {
            appId: appId,
            type: $('#intType').val(),
            date: dateVal,
            location: $('#intLocation').val(),
            interviewer: $('#intInterviewer').val(),
            email: $('#intEmail').val(),
            notes: $('#intNotes').val(),
            internalNotes: $('#internalNotes').val(),
            status: $('#intStatus').val()
        };

        $.post('/Employeer/ScheduleInterview', payload, function (res) {
            if (res.success) {
                // hide modal with compatible method
                if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                    var el = document.querySelector('#scheduleModal');
                    var inst = bootstrap.Modal.getInstance(el);
                    if (inst) inst.hide();
                } else if (typeof $ !== 'undefined' && $.fn && $.fn.modal) {
                    $('#scheduleModal').modal('hide');
                }
                
                alert("Interview saved successfully.");
                location.reload();
            } else {
                alert("Error: " + res.message);
            }
        }).fail(function (xhr) {
            console.error(xhr.responseText);
            alert("A server error occurred. Check console for details.");
        });
    }
</script>