@model List<Job_Portal_System.ViewModel.SavedJobViewModel>
@{
    Layout = "~/Views/Shared/_JobSeekerDashboard.cshtml";
}

<style>
    .page-title {
        color: #002E7F;
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 20px;
    }

    .table-modern {
        width: 100%;
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        border-collapse: collapse;
    }

        .table-modern th {
            background: #002E7F;
            color: white;
            padding: 15px;
            font-weight: 600;
            text-align: left;
        }

        .table-modern td {
            padding: 15px;
            border-bottom: 1px solid #eee;
            vertical-align: middle;
        }

    /* Professional Status Badges */
    .badge-status {
        padding: 6px 10px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .status-saved {
        background: #e3f2fd;
        color: #0d47a1;
    }
    /* Blue */
    .status-applied {
        background: #fff3e0;
        color: #ef6c00;
    }
    /* Orange */
    .status-interview {
        background: #f3e5f5;
        color: #7b1fa2;
    }
    /* Purple */
    .status-expired {
        background: #ffebee;
        color: #c62828;
    }
    /* Red */

    .btn-action {
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        font-size: 13px;
        margin-right: 5px;
        transition: 0.3s;
    }

    .btn-view {
        background: #002E7F;
        color: white;
        border: none;
    }

        .btn-view:hover {
            background: #001f54;
            color: white;
        }

    .btn-notes {
        background: #f8f9fa;
        color: #333;
        border: 1px solid #ddd;
    }

        .btn-notes:hover {
            background: #e9ecef;
        }

    .btn-remove {
        background: #FF4B4B;
        color: white;
        border: none;
    }

        .btn-remove:hover {
            background: #d43f3f;
            color: white;
        }

    .text-muted-small {
        color: #888;
        font-size: 12px;
        display: block;
    }
</style>
<h2 class="page-title">My Job Tracker</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info" style="border-radius: 10px;">
        <strong>No saved jobs!</strong> Start exploring and save jobs you're interested in.
    </div>
}
else
{
    <table class="table-modern">
        <thead>
            <tr>
                <th>Job & Company</th>
                <th>Status</th>
                <th>Saved Date</th>
                <th>Deadline</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr style="@(item.IsExpired ? "opacity: 0.7; background-color: #fafafa;" : "")">
                    <td>
                        <span style="font-weight: 700; color: #333; font-size: 16px;">@item.JobTitle</span><br />
                        <span class="text-muted-small" style="font-size: 12px; color: #777;">@item.CompanyName • @item.Location</span>
                    </td>
                    <td>
                        @if (item.IsExpired)
                        {<span class="badge-status status-expired">Expired</span> }
                        else if (item.Status == 2)
                        { <span class="badge-status status-applied">Applied</span> }
                        else if (item.Status == 3)
                        { <span class="badge-status status-interview">Interviewing</span> }
                        else
                        { <span class="badge-status status-saved">Saved</span>}
                    </td>
                    <td style="color: #666; font-size: 14px;">@item.SavedAt.ToString("MMM dd, yyyy")</td>
                    <td style="font-size: 14px;">@(item.Deadline.HasValue ? item.Deadline.Value.ToString("MMM dd, yyyy") : "N/A")</td>
                    <td>
                        <div style="display: flex; gap: 8px;">
                            <a href="@Url.Action("JobDetails", "Job", new { id = item.JobID })" class="btn-action btn-view">Details</a>

                            <button type="button" class="btn-action"
                                    style="background: #f0f4ff; color: #002E7F; border: 1px solid #002E7F; border-radius: 5px; padding: 5px 10px;"
                                    onclick="openNotesModal(@item.JobID, this.getAttribute('data-notes'))" data-notes="@item.Notes">View Notes
                                <i class="fa fa-sticky-note"></i>
                            </button>

                            <a href="@Url.Action("RemoveSavedJob", "SavedJobs", new { jobId = item.JobID })"
                               class="btn-action btn-remove"
                               style="color: red;"
                               onclick="return confirm('Remove this job from your list?')">Remove</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="modal fade" id="notesModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 15px; border: none;">
                <div class="modal-header" style="background: #002E7F; color: white; border-radius: 15px 15px 0 0;">
                    <h5 class="modal-title">Job Application Notes</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="modalSavedJobId" />

                    <input type="hidden" id="modalSavedSeekerId" value="@Session["UserId"]" />

                    <label class="mb-2" style="font-weight: 600; color: #333;">Personal Remarks / Interview Details:</label>
                    <textarea id="modalNotesText" class="form-control" rows="5"
                              placeholder="Example: Interview on 10th April..."
                              style="border-radius: 10px; border: 1px solid #ddd;"></textarea>
                </div>
                <div class="modal-footer" style="border-top: none;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" onclick="saveNotes()"
                            style="background: #002E7F; border: none; padding: 8px 25px;">
                        Save Note
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<script>
    function openNotesModal(savedJobId, currentNotes) {
        console.log("Job ID:", savedJobId);
        console.log("Fetched Notes:", currentNotes);

        $('#modalSavedJobId').val(savedJobId);

        if (currentNotes && currentNotes !== "null") {
            $('#modalNotesText').val(currentNotes);
        } else {
            $('#modalNotesText').val(""); 
        }

        $('#notesModal').modal('show');
    }

    function saveNotes() {
        var id = $('#modalSavedJobId').val();
        var notes = $('#modalNotesText').val();
        console.log("save notes" , id)
        console.log(notes)

        $.ajax({
            url: '/SavedJobs/UpdateNotes',
            type: 'POST',
            data: { id: id, notes: notes },
            success: function (response) {
                if (response.success) {
                    $('#notesModal').modal('hide');
                    location.reload();
                } else {
                    alert("Error: " + response.message);
                }
            },
            error: function (xhr) {
                console.log(xhr.responseText);
                alert("Critical Error. Check console for details.");
            }
        });
    }
</script>